---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const title = 'Live Life Customs · Selected work · Rekraft Design';
const description = 'Streetwear brand revival. Bold visual system, custom apparel portfolio, Instagram-only intake. Case study by Rekraft Design.';
const canonical = 'https://rekraft.design/work/livelifecustoms';

const works = [
  { src: '/images/work/llc/01-curmah.jpg', title: 'Curmah Joseph', meta: 'Dark Paradise · Soleil Estée · Gold foil' },
  { src: '/images/work/llc/04-nasa.jpg', title: 'NASA Astronaut', meta: 'Apollo 11 tribute · Three badges, Saturn V' },
  { src: '/images/work/llc/06-glute-chaser.jpg', title: 'Glute Chaser Programme', meta: 'Cursive script · Real product on tee' },
  { src: '/images/work/llc/09-samesame.png', title: 'Same Same', meta: 'Off-White parody · Real hoodie mockup' },
  { src: '/images/work/llc/02-atlantic.jpg', title: 'Atlantic Culture', meta: 'Fire-sleeve · Dripping-earth graphic' },
  { src: '/images/work/llc/03-oficianado.png', title: 'Oficianado Kigali', meta: 'Cigar brand identity · Tee mockup' },
];

const palette = [
  { name: 'Off-black', hex: '#0E0E10' },
  { name: 'Cyan', hex: '#20B6FF' },
  { name: 'Orange', hex: '#FF6A2C' },
  { name: 'Warm white', hex: '#FAFAFA' },
];
---

<Base title={title} description={description} canonical={canonical}>
  <Nav />
  <main class="case">
    <div class="frame case-back-wrap">
      <a href="/#work" class="case-back font-mono">&larr; Selected Work</a>
    </div>

    <section class="section case-intro">
      <div class="frame">
        <header class="case-head">
          <span class="eyebrow">C &middot; Brand-forward</span>
          <h1 class="display-1 reveal-words" data-hero-headline>
            Live Life Customs. <em class="italic-accent">Custom everything.</em>
          </h1>
          <p class="lead fade-up">
            A dormant streetwear brand, brought back. New visual system, IG-only intake, ready to take orders again.
          </p>
          <div class="case-meta fade-up font-mono">
            <span>Brand</span>
            <span aria-hidden="true">&middot;</span>
            <span>Website</span>
            <span aria-hidden="true">&middot;</span>
            <span>2026</span>
          </div>
          <a href="https://livelifecustoms.vercel.app" target="_blank" rel="noopener" class="btn btn-primary case-cta-link fade-up">
            View live site <span class="case-arrow-up">&#8599;</span>
          </a>
        </header>
      </div>
    </section>

    <section class="section case-block">
      <div class="frame">
        <div class="case-grid">
          <div class="case-block-head">
            <span class="eyebrow">01 &middot; Brief</span>
            <h2 class="display-2 reveal-words" data-reveal-headline>
              Three jobs. <em class="italic-accent">One brand.</em>
            </h2>
          </div>
          <ol class="case-list">
            <li class="fade-up">
              <span class="case-list-num font-mono">01</span>
              <h3 class="display-3">Revived brand</h3>
              <p>LLC sat archived after years of custom apparel work. Equipment still here, 26-client portfolio archived. The site re-establishes LLC as a living brand, accepting commissions.</p>
            </li>
            <li class="fade-up">
              <span class="case-list-num font-mono">02</span>
              <h3 class="display-3">Portfolio piece</h3>
              <p>Demonstrates Rekraft Design's range. Editorial cream is one register, this is the other end. Bold streetwear, opposite of restraint, same craft.</p>
            </li>
            <li class="fade-up">
              <span class="case-list-num font-mono">03</span>
              <h3 class="display-3">Family coherence</h3>
              <p>Three sibling sites under the Rekraft umbrella. Same build discipline, distinct visual languages: cream studio, dark trades agency, black streetwear.</p>
            </li>
          </ol>
        </div>
      </div>
    </section>

    <section class="section case-block">
      <div class="frame">
        <div class="case-grid">
          <div class="case-block-head">
            <span class="eyebrow">02 &middot; System</span>
            <h2 class="display-2 reveal-words" data-reveal-headline>
              Street Bold. <em class="italic-accent">Built to last.</em>
            </h2>
          </div>
          <div class="case-system">
            <div class="case-palette">
              {palette.map((p) => (
                <div class="case-swatch fade-up">
                  <div class="case-swatch-color" style={`background:${p.hex}`}></div>
                  <div class="case-swatch-name font-mono">{p.name}</div>
                  <div class="case-swatch-hex font-mono">{p.hex}</div>
                </div>
              ))}
            </div>
            <div class="case-typography fade-up">
              <div class="case-type-display">LIVE BOLD.</div>
              <div class="case-type-meta font-mono">Archivo Black &middot; Display</div>
            </div>
            <ul class="case-system-notes">
              <li class="fade-up">No 3D tilt: wrong register for streetwear</li>
              <li class="fade-up">Cyan cursor-arrow points at the IG CTA</li>
              <li class="fade-up">Three rotating section-label variants (block, badge, tape)</li>
              <li class="fade-up">No contact form, Instagram is the only channel</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="section case-block">
      <div class="frame">
        <header class="case-portfolio-head">
          <span class="eyebrow">03 &middot; Selected client work</span>
          <h2 class="display-2 reveal-words" data-reveal-headline>
            Real client work. <em class="italic-accent">Real product.</em>
          </h2>
          <p class="lead fade-up">
            Years of custom apparel. Imagery is owned, not stock.
          </p>
        </header>
        <div class="case-gallery">
          {works.map((w) => (
            <figure class="case-figure fade-up">
              <img src={w.src} alt={w.title} loading="lazy" decoding="async" />
              <figcaption>
                <div class="case-figure-title font-mono">{w.title}</div>
                <div class="case-figure-meta font-mono">{w.meta}</div>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="section case-block case-cta">
      <div class="frame">
        <div class="case-cta-inner">
          <span class="eyebrow">04 &middot; Outcome</span>
          <h2 class="display-2 reveal-words" data-reveal-headline>
            Shipped. <em class="italic-accent">Then iterated.</em>
          </h2>
          <ul class="case-stats">
            <li class="fade-up">
              <span class="case-stat-num font-display">11</span>
              <span class="case-stat-label font-mono">case studies + open slot</span>
            </li>
            <li class="fade-up">
              <span class="case-stat-num font-display">6</span>
              <span class="case-stat-label font-mono">services priced honestly</span>
            </li>
            <li class="fade-up">
              <span class="case-stat-num font-display">1</span>
              <span class="case-stat-label font-mono">channel (Instagram)</span>
            </li>
          </ul>
          <a href="https://livelifecustoms.vercel.app" target="_blank" rel="noopener" class="btn btn-primary case-cta-btn">
            View the live site <span class="case-arrow-up">&#8599;</span>
          </a>
          <a href="/#work" class="case-back-bottom font-mono">&larr; All selected work</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .case-back-wrap {
    padding-top: clamp(96px, 12vw, 140px);
  }
  .case-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-ink-dim);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: color .35s var(--ease-out-expo);
  }
  .case-back:hover { color: var(--color-ink); }

  .case-intro {
    padding-block: clamp(40px, 6vw, 80px) clamp(80px, 10vw, 120px);
  }
  .case-head {
    display: grid;
    gap: 24px;
    max-width: 1080px;
  }
  .case-meta {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
    padding-top: 8px;
  }
  .case-cta-link { justify-self: start; margin-top: 8px; }
  .case-arrow-up {
    display: inline-block;
    transition: transform .4s var(--ease-out-expo);
  }
  .btn:hover .case-arrow-up { transform: translate(3px, -3px); }

  .case-block {
    border-top: 1px solid var(--color-border);
    padding-block: clamp(80px, 10vw, 140px);
  }
  .case-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(48px, 8vw, 140px);
    align-items: start;
  }
  .case-block-head {
    position: sticky;
    top: 120px;
    align-self: start;
    display: grid;
    gap: 16px;
  }

  /* Brief list */
  .case-list {
    list-style: none;
    display: grid;
    gap: 1px;
    background: var(--color-border);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .case-list li {
    background: var(--color-bg);
    padding: clamp(28px, 4vw, 56px) 0;
    padding-left: clamp(20px, 2.5vw, 40px);
    display: grid;
    grid-template-columns: 60px 1fr;
    column-gap: clamp(20px, 3vw, 40px);
    row-gap: 14px;
    align-items: baseline;
    transition: background .5s var(--ease-out-expo);
  }
  .case-list li:hover { background: var(--color-surface); }
  .case-list-num {
    grid-row: span 2;
    color: var(--color-lime);
    font-size: 11px;
    letter-spacing: 0.2em;
    padding-top: 12px;
  }
  .case-list h3 { color: var(--color-ink); }
  .case-list p {
    grid-column: 2;
    color: var(--color-ink-muted);
    font-size: clamp(15px, 0.6vw + 12px, 18px);
    line-height: 1.65;
    max-width: 60ch;
  }

  /* System block */
  .case-system { display: grid; gap: 40px; }
  .case-palette {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }
  .case-swatch {
    background: var(--color-bg);
    padding: 24px 20px;
    display: grid;
    gap: 10px;
  }
  .case-swatch-color {
    height: 80px;
    border: 1px solid var(--color-border);
  }
  .case-swatch-name {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink);
  }
  .case-swatch-hex {
    font-size: 10px;
    color: var(--color-ink-dim);
    letter-spacing: 0.1em;
  }
  .case-typography {
    background: #0E0E10;
    padding: clamp(40px, 5vw, 64px);
    border: 1px solid var(--color-border);
  }
  .case-type-display {
    font-family: 'Archivo Black', 'Inter Tight', sans-serif;
    font-weight: 900;
    font-size: clamp(48px, 8vw, 120px);
    line-height: 0.95;
    letter-spacing: -0.01em;
    color: #FAFAFA;
    text-transform: uppercase;
  }
  .case-type-meta {
    margin-top: 16px;
    color: #20B6FF;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .case-system-notes {
    list-style: none;
    display: grid;
    gap: 12px;
  }
  .case-system-notes li {
    color: var(--color-ink-muted);
    font-size: 14px;
    line-height: 1.5;
    padding-left: 18px;
    position: relative;
  }
  .case-system-notes li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-lime);
  }

  /* Portfolio gallery */
  .case-portfolio-head {
    display: grid;
    gap: 16px;
    max-width: 720px;
    margin-bottom: clamp(48px, 6vw, 80px);
  }
  .case-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 2.5vw, 40px);
  }
  .case-figure {
    display: grid;
    gap: 14px;
  }
  .case-figure img {
    aspect-ratio: 4 / 5;
    width: 100%;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: #0E0E10;
    transition: transform .8s var(--ease-out-expo);
  }
  .case-figure:hover img { transform: scale(1.02); }
  .case-figure-title {
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink);
  }
  .case-figure-meta {
    font-size: 10px;
    color: var(--color-ink-dim);
    letter-spacing: 0.08em;
  }

  /* Outcome */
  .case-cta-inner {
    display: grid;
    gap: 28px;
    max-width: 880px;
  }
  .case-stats {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin-block: 16px;
  }
  .case-stats li {
    background: var(--color-bg);
    padding: clamp(28px, 4vw, 48px) 24px;
    display: grid;
    gap: 8px;
  }
  .case-stat-num {
    font-size: clamp(48px, 6vw, 80px);
    line-height: 1;
    color: var(--color-ink);
    letter-spacing: -0.02em;
    padding-bottom: 0.05em;
  }
  .case-stat-label {
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }
  .case-cta-btn { justify-self: start; }
  .case-back-bottom {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
    transition: color .35s var(--ease-out-expo);
  }
  .case-back-bottom:hover { color: var(--color-ink); }

  @media (max-width: 1100px) {
    .case-grid { grid-template-columns: 1fr; gap: clamp(32px, 5vw, 64px); }
    .case-block-head { position: static; }
    .case-palette { grid-template-columns: repeat(2, 1fr); }
    .case-gallery { grid-template-columns: repeat(2, 1fr); }
    .case-stats { grid-template-columns: 1fr; }
  }

  @media (max-width: 700px) {
    .case-list li { grid-template-columns: 1fr; gap: 12px; padding-left: 20px; }
    .case-list-num { grid-row: auto; padding-top: 0; }
    .case-list p { grid-column: 1; }
    .case-gallery { grid-template-columns: 1fr; }
  }
</style>
