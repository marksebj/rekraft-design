---
---
<section id="about" class="section about">
  <div class="frame">
    <header class="about-head">
      <span class="eyebrow">04 &middot; About</span>
      <h2 class="display-2 reveal-words" data-reveal-headline>
        A studio built by a <em class="italic-accent">lifelong maker.</em>
      </h2>
    </header>

    <div class="about-grid">
      <div class="about-text fade-up">
        <p class="about-lead">
          The studio arm of Rekraft. For founders and businesses that care how they&rsquo;re seen.
        </p>
        <p>
          15 years designing brands, websites, and creative work for founders, artists, and businesses that know good from generic.
        </p>
        <p>
          Designer. Systems thinker. Big-picture obsessive. At home on a brand, a website, or the art direction for a physical space.
        </p>
        <p>
          Small studio. Deep network. Trusted partnerships with photographers, developers, copywriters, and art directors across London. Every project ships with the right specialists on it. No juniors, no filler.
        </p>
        <p>
          Fifteen years in. Still obsessed.
        </p>
        <div class="about-stats">
          <div class="about-stat">
            <span class="about-stat-num font-display">15+</span>
            <span class="about-stat-label font-mono">years making</span>
          </div>
          <div class="about-stat">
            <span class="about-stat-num font-display">100s</span>
            <span class="about-stat-label font-mono">projects shipped</span>
          </div>
          <div class="about-stat">
            <span class="about-stat-num font-display">1</span>
            <span class="about-stat-label font-mono">point of view</span>
          </div>
        </div>
      </div>

      <aside class="about-founder fade-up">
        <div class="about-founder-img">
          <img src="/images/mark-founder.jpg" alt="Mark, founder of Rekraft Design" loading="lazy" />
        </div>
        <div class="about-founder-meta">
          <div class="about-founder-name-wrap">
            <h3 class="about-founder-name display-3">Mark</h3>
            <span class="about-founder-role font-mono">Founder</span>
          </div>
          <p class="about-founder-bio">
            15 years designing brands, websites, and creative work for founders, artists, and businesses that care about craft.
          </p>
          <p class="about-founder-bio">
            Runs Rekraft Design. Brings in trusted London specialists when a project calls for them: photographers, developers, writers, art directors.
          </p>
          <dl class="about-founder-details">
            <div><dt class="font-mono">Based</dt><dd>London, UK</dd></div>
            <div><dt class="font-mono">Discipline</dt><dd>Brand. Web. Space.</dd></div>
            <div><dt class="font-mono">Available</dt><dd>Q3 2026</dd></div>
          </dl>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .about {
    border-top: 1px solid var(--color-border);
    padding-block: clamp(100px, 12vw, 180px);
  }

  .about-head {
    display: grid;
    gap: 20px;
    max-width: 960px;
    margin-bottom: clamp(56px, 8vw, 100px);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: clamp(40px, 6vw, 100px);
    align-items: start;
  }

  .about-text { display: grid; gap: 18px; }
  .about-lead {
    font-family: var(--font-display);
    font-size: clamp(22px, 1.8vw + 12px, 32px);
    line-height: 1.3;
    color: var(--color-ink);
    margin-bottom: 8px;
  }
  .about-text p:not(.about-lead) {
    font-size: clamp(15px, 0.6vw + 12px, 18px);
    line-height: 1.7;
    color: var(--color-ink-muted);
    max-width: 60ch;
  }
  .about-text p:last-of-type {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-cream);
    font-size: clamp(18px, 1vw + 12px, 24px);
    line-height: 1.4;
    padding-top: 4px;
  }

  .about-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 32px;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }
  .about-stat { display: grid; gap: 6px; }
  .about-stat-num {
    font-size: clamp(36px, 3vw + 16px, 56px);
    line-height: 1;
    color: var(--color-ink);
    letter-spacing: -0.02em;
  }
  .about-stat-label {
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }

  .about-founder {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: clamp(24px, 2vw, 32px);
    display: grid;
    gap: 24px;
    position: sticky;
    top: 120px;
  }
  .about-founder-img {
    aspect-ratio: 4 / 5;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }
  .about-founder-img img { width: 100%; height: 100%; object-fit: cover; }

  .about-founder-meta { display: grid; gap: 16px; }
  .about-founder-name-wrap { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; }
  .about-founder-name { line-height: 1; }
  .about-founder-role {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-cream);
  }
  .about-founder-bio {
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-ink-muted);
  }
  .about-founder-bio:first-of-type {
    color: var(--color-ink);
    font-weight: 500;
  }

  .about-founder-details {
    display: grid;
    gap: 14px;
    padding-top: 16px;
    border-top: 1px solid var(--color-border);
  }
  .about-founder-details > div {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 16px;
    align-items: baseline;
  }
  .about-founder-details dt {
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }
  .about-founder-details dd {
    font-size: 14px;
    color: var(--color-ink);
  }

  @media (max-width: 900px) {
    .about-grid { grid-template-columns: 1fr; gap: 48px; }
    .about-founder { position: static; }
    .about-stats { grid-template-columns: 1fr; gap: 16px; }
  }
</style>
