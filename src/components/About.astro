---
const profile = {
  name: 'Mark',
  title: 'Founder · Rekraft Design',
  imageUrl: '/images/mark-founder.jpg',
  bio: '15 years designing brands, websites, and creative work for founders, artists, and businesses that know good from generic. Designer. Systems thinker. Big-picture obsessive.',
  partners: 'Small studio. Deep network. Trusted London partnerships with photographers, developers, copywriters, and art directors. Every project ships with the right specialists on it.',
  closer: 'Fifteen years in. Still obsessed.',
  socials: [
    { label: 'Email Mark', url: 'mailto:mark@rekraft.design', svg: 'mail' },
    { label: 'LinkedIn', url: '#', svg: 'linkedin' },
    { label: 'Instagram', url: '#', svg: 'instagram' },
  ],
};
---

<section id="about" class="section about">
  <div class="frame">
    <header class="about-head">
      <span class="eyebrow">04 &middot; About</span>
      <h2 class="display-2 reveal-words" data-reveal-headline>
        A studio built by a <em class="italic-accent">lifelong maker.</em>
      </h2>
      <p class="lead fade-up">
        The studio arm of Rekraft. For founders and businesses that care how they&rsquo;re seen.
      </p>
    </header>

    <div class="about-profile fade-up">
      <div class="about-profile-img">
        <img
          src={profile.imageUrl}
          alt={`${profile.name}, founder of Rekraft Design`}
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="about-profile-card">
        <header class="about-profile-head">
          <h3 class="about-profile-name">{profile.name}</h3>
          <p class="about-profile-title font-mono">{profile.title}</p>
        </header>
        <p class="about-profile-bio">{profile.bio}</p>
        <p class="about-profile-bio">{profile.partners}</p>
        <p class="about-profile-closer italic-accent">{profile.closer}</p>
        <div class="about-profile-socials">
          {profile.socials.map((s) => (
            <a
              href={s.url}
              target={s.url.startsWith('http') ? '_blank' : undefined}
              rel={s.url.startsWith('http') ? 'noopener noreferrer' : undefined}
              class="about-profile-social"
              aria-label={s.label}
            >
              {s.svg === 'mail' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                  <path d="m22 7-10 5L2 7"></path>
                </svg>
              )}
              {s.svg === 'linkedin' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                  <rect x="2" y="9" width="4" height="12"></rect>
                  <circle cx="4" cy="4" r="2"></circle>
                </svg>
              )}
              {s.svg === 'instagram' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="20" rx="5"></rect>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    border-top: 1px solid var(--color-border);
    padding-block: clamp(56px, 6vw, 96px);
  }

  .about-head {
    display: grid;
    gap: 14px;
    max-width: 720px;
    margin-bottom: clamp(36px, 4vw, 64px);
  }

  /* Profile-card pattern: square portrait + overlapping bio card */
  .about-profile {
    display: flex;
    align-items: center;
    max-width: 1100px;
  }

  .about-profile-img {
    flex: 0 0 auto;
    width: 460px;
    height: 460px;
    border-radius: 24px;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }
  .about-profile-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    user-select: none;
  }

  .about-profile-card {
    position: relative;
    z-index: 2;
    flex: 1 1 auto;
    max-width: 560px;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 24px;
    padding: clamp(28px, 2.6vw + 8px, 44px);
    margin-left: -80px;
    display: grid;
    gap: 16px;
    box-shadow: 0 30px 80px -42px rgba(20, 20, 24, 0.32);
  }

  .about-profile-head {
    display: grid;
    gap: 8px;
    margin-bottom: 4px;
  }
  .about-profile-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(32px, 2.6vw + 12px, 48px);
    line-height: 1;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    padding-bottom: 0.04em;
  }
  .about-profile-title {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }

  .about-profile-bio {
    font-size: clamp(14px, 0.4vw + 12px, 16px);
    line-height: 1.65;
    color: var(--color-ink-muted);
  }
  .about-profile-bio:first-of-type {
    color: var(--color-ink);
  }

  .about-profile-closer {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-cream);
    font-size: clamp(18px, 1vw + 10px, 24px);
    line-height: 1.3;
    margin-top: 6px;
    padding-top: 16px;
    border-top: 1px solid var(--color-border);
  }

  /* Social icons: dark circles with light glyphs */
  .about-profile-socials {
    display: flex;
    gap: 12px;
    margin-top: 8px;
  }
  .about-profile-social {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-ink);
    color: var(--color-bg);
    display: grid;
    place-items: center;
    transition:
      background 0.3s var(--ease-out-expo),
      transform 0.3s var(--ease-out-expo);
  }
  .about-profile-social:hover {
    background: #000;
    transform: translateY(-2px);
  }
  .about-profile-social svg {
    width: 18px;
    height: 18px;
  }

  /* Tablet: shrink portrait so the overlap still works */
  @media (max-width: 1100px) {
    .about-profile-img {
      width: 360px;
      height: 360px;
    }
  }

  /* Mobile: stack image on top, card slides up under it */
  @media (max-width: 800px) {
    .about-profile {
      flex-direction: column;
      align-items: stretch;
    }
    .about-profile-img {
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
    }
    .about-profile-card {
      margin-left: 0;
      margin-top: -36px;
      max-width: 100%;
    }
  }
</style>
