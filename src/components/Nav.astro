---
---
<nav data-nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Rekraft Design home">
      <img src="/images/ReKraft Logo.png" alt="" width="32" height="32" />
      <span class="nav-wordmark">
        <span class="nav-brand">rekraft</span>
        <span class="nav-brand-sub">design</span>
      </span>
    </a>
    <div class="nav-links">
      <a href="#work">Work</a>
      <a href="#approach">Approach</a>
      <a href="#services">Services</a>
      <a href="#investment">Investment</a>
      <a href="#about">About</a>
    </div>
    <a href="#contact" class="nav-cta">
      <span>Start a project</span>
      <span class="btn-arrow">&rarr;</span>
    </a>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: clamp(16px, 2vw, 28px) clamp(20px, 4vw, 80px);
    transition: padding .5s var(--ease-out-expo);
    pointer-events: none;
  }
  .nav.is-scrolled {
    padding: 14px clamp(20px, 4vw, 80px);
  }
  .nav-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 24px;
    max-width: 1440px;
    margin-inline: auto;
    padding: 10px 14px 10px 18px;
    background: rgba(242, 237, 225, 0.78);
    backdrop-filter: saturate(130%) blur(14px);
    -webkit-backdrop-filter: saturate(130%) blur(14px);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    pointer-events: auto;
    transition: background .4s var(--ease-out-expo), border-color .4s var(--ease-out-expo);
    box-shadow: 0 10px 30px -20px rgba(20, 20, 24, 0.15);
  }
  .nav.is-scrolled .nav-inner {
    background: rgba(242, 237, 225, 0.92);
    border-color: var(--color-border-active);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .nav-logo img {
    display: block;
    width: 28px;
    height: 28px;
    border-radius: 6px;
  }
  .nav-wordmark {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .nav-brand {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }
  .nav-brand-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 16px;
    color: var(--color-cream);
    opacity: 0.85;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    justify-content: center;
  }
  .nav-links a {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-ink-muted);
    position: relative;
    transition: color .3s var(--ease-out-expo);
  }
  .nav-links a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -6px;
    width: 0;
    height: 1px;
    background: var(--color-lime);
    transition: width .4s var(--ease-out-expo);
  }
  .nav-links a:hover { color: var(--color-ink); }
  .nav-links a:hover::after { width: 100%; }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-bg);
    background: var(--color-ink);
    padding: 11px 22px;
    border-radius: 999px;
    transition: background .35s var(--ease-out-expo), transform .35s var(--ease-out-expo);
  }
  .nav-cta:hover {
    background: #FFFFFF;
    transform: translateY(-1px);
  }
  .btn-arrow {
    display: inline-block;
    transition: transform .35s var(--ease-out-expo);
  }
  .nav-cta:hover .btn-arrow { transform: translateX(3px); }

  @media (max-width: 900px) {
    .nav-links { display: none; }
    .nav-inner { grid-template-columns: auto 1fr; }
  }
  @media (max-width: 520px) {
    .nav-cta span:first-child { display: none; }
    .nav-cta { padding: 10px 14px; }
  }
</style>
