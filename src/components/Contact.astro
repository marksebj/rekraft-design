---
---
<section id="contact" class="section contact">
  <div class="contact-bg" aria-hidden="true">
    <div class="contact-glow"></div>
  </div>

  <div class="frame contact-inner">
    <span class="eyebrow">05 &mdash; Get in touch</span>

    <h2 class="display-1 reveal-words" data-reveal-headline>
      Start a <em class="italic-accent">project.</em>
    </h2>

    <p class="lead fade-up contact-lead">
      We reply within 24 hours. If it&rsquo;s a fit, we book a call. If not, we point you somewhere better.
    </p>

    <div class="contact-actions fade-up">
      <a class="contact-email" href="mailto:mark@rekraft.design?subject=New%20project%20enquiry" data-magnetic="0.08">
        <span class="contact-email-label font-mono">Write to</span>
        <span class="contact-email-addr display-3">mark@rekraft.design</span>
        <span class="contact-email-arrow">&rarr;</span>
      </a>
    </div>

    <ul class="contact-meta font-mono fade-up">
      <li>Small roster</li>
      <li>Selective intake</li>
      <li>London · worldwide</li>
      <li>Q3 2026 availability</li>
    </ul>
  </div>
</section>

<style>
  .contact {
    border-top: 1px solid var(--color-border);
    padding-block: clamp(120px, 16vw, 220px);
    position: relative;
    overflow: hidden;
  }
  .contact-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .contact-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(80vw, 900px);
    height: min(80vw, 900px);
    background: radial-gradient(circle at center, var(--color-ambient) 0%, transparent 55%);
  }

  .contact-inner {
    position: relative;
    z-index: 1;
    display: grid;
    gap: clamp(28px, 4vw, 48px);
    text-align: left;
  }
  .contact-inner h2 { max-width: 11ch; }

  .contact-lead { max-width: 42ch; }

  .contact-actions {
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 24px;
  }
  .contact-email {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: clamp(16px, 3vw, 40px);
    padding: clamp(16px, 2vw, 28px) 0;
    transition: transform .5s var(--ease-out-expo);
  }
  .contact-email:hover { transform: translateX(8px); }
  .contact-email-label {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }
  .contact-email-addr {
    font-size: clamp(28px, 5vw, 72px);
    color: var(--color-ink);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .contact-email-arrow {
    font-size: clamp(28px, 3vw, 48px);
    color: var(--color-lime);
    transition: transform .5s var(--ease-out-expo);
  }
  .contact-email:hover .contact-email-arrow { transform: translateX(10px) rotate(-20deg); }

  .contact-meta {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 14px 24px;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
    padding-top: 8px;
  }
  .contact-meta li {
    position: relative;
    padding-left: 14px;
  }
  .contact-meta li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    width: 5px;
    height: 5px;
    border-radius: 1px;
    background: var(--color-lime);
    transform: translateY(-50%) rotate(45deg);
  }
</style>
