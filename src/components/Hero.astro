---
---
<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-grain"></div>
    <div class="hero-glow"></div>
  </div>

  <div class="frame hero-inner">
    <div class="hero-top">
      <span class="eyebrow" data-hero-eyebrow>
        Independent design studio · London
      </span>
      <span class="hero-year font-mono" data-hero-eyebrow>Est. 2026</span>
    </div>

    <div class="hero-body" data-tilt3d-parent>
      <h1 class="display-1 reveal-words hero-headline" data-hero-headline data-tilt3d>
        Made to stand out.<br /><em class="italic-accent">Built to stand up.</em>
      </h1>
    </div>

    <div class="hero-foot">
      <p class="lead" data-hero-sub>
        Brand, websites, and social for brands that mean business.
      </p>
      <div class="hero-ctas" data-hero-ctas>
        <a href="#work" class="btn btn-primary" data-magnetic="0.25">
          See the work <span class="btn-arrow">&rarr;</span>
        </a>
        <a href="#contact" class="btn btn-ghost" data-magnetic="0.2">Start a project</a>
      </div>
    </div>

    <div class="hero-scroll-cue" aria-hidden="true">
      <span>scroll</span>
      <span class="hero-scroll-line"></span>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: grid;
    align-items: end;
    padding-top: 120px;
    padding-bottom: clamp(48px, 6vw, 80px);
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .hero-glow {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 75%;
    height: 90%;
    background: radial-gradient(ellipse at 70% 40%, var(--color-ambient) 0%, transparent 55%);
  }
  .hero-grain {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 1px 1px, rgba(20, 20, 24, 0.06) 1px, transparent 0);
    background-size: 3px 3px;
    opacity: 0.55;
    mix-blend-mode: multiply;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: clamp(32px, 4vw, 64px);
    min-height: calc(100svh - 120px);
    width: 100%;
  }

  .hero-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }
  .hero-year {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }

  .hero-body {
    display: block;
    width: 100%;
    perspective: 1400px;
    perspective-origin: 50% 50%;
    min-height: clamp(280px, 42vh, 520px);
    display: flex;
    align-items: center;
    padding-block: clamp(20px, 4vw, 60px);
  }

  .hero-headline {
    max-width: 20ch;
    transform-style: preserve-3d;
    will-change: transform;
    cursor: grab;
    user-select: none;
    /* subtle double-layer shadow gives the type dimensional weight when it rotates */
    text-shadow:
      0 1px 0 rgba(20, 20, 24, 0.02),
      0 8px 40px rgba(20, 20, 24, 0.06);
  }
  .hero-headline:active { cursor: grabbing; }
  .hero-headline em { font-style: italic; }

  .hero-foot {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }
  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .hero-scroll-cue {
    position: absolute;
    right: 0;
    bottom: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
    writing-mode: vertical-rl;
  }
  .hero-scroll-line {
    writing-mode: horizontal-tb;
    display: block;
    width: 1px;
    height: 56px;
    background: linear-gradient(to bottom, var(--color-ink-dim), transparent);
    animation: scroll-pulse 2.4s var(--ease-out-expo) infinite;
  }
  @keyframes scroll-pulse {
    0%, 100% { transform: scaleY(0.5); transform-origin: top; opacity: 0.4; }
    50% { transform: scaleY(1); transform-origin: top; opacity: 1; }
  }

  @media (max-width: 900px) {
    .hero { padding-top: 100px; }
    .hero-body { perspective: 1000px; min-height: auto; }
    .hero-foot {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .hero-scroll-cue { display: none; }
  }
  @media (max-width: 520px) {
    .hero-top { flex-direction: column; align-items: flex-start; gap: 8px; }
  }
</style>
