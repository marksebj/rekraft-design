---
---
<section class="hero" data-hero>
  <video
    class="hero-video"
    data-hero-video
    src="/videos/hero.mp4"
    poster="/images/hero-poster.jpg"
    autoplay
    muted
    loop
    playsinline
    webkit-playsinline
    preload="auto"
    aria-hidden="true"
  ></video>
  <!-- Tap-to-play hint. Hidden by default. Shown only if autoplay was
       blocked by the OS (iOS Low Power Mode, Reduce Motion, etc.) so the
       user has a clear affordance to start playback. Fades out once the
       video reports it's actually playing. -->
  <button
    class="hero-play-hint"
    data-hero-play-hint
    type="button"
    aria-label="Play hero video"
    hidden
  >
    <span class="hero-play-hint-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path d="M8 5v14l11-7z" />
      </svg>
    </span>
    <span class="hero-play-hint-label">Tap to play</span>
  </button>

  <!-- Bottom-edge fade so the dark video bleeds into the cream Manifesto
       section below rather than ending on a hard horizontal cut. -->
  <div class="hero-veil" aria-hidden="true"></div>
</section>

<style>
  /* Cinematic full-bleed video hero. No type overlay (returning later).
     Black surface under the video so there is no cream flash before the
     first frame paints; cream-fade at the bottom edge dissolves into the
     Manifesto section. */
  .hero {
    position: relative;
    height: 100svh;
    width: 100%;
    overflow: hidden;
    background: #000;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transition: opacity 1.2s var(--ease-out-expo);
    will-change: opacity;
  }
  .hero-video.is-ready {
    opacity: 1;
  }

  /* Tap-to-play hint. Visible only when autoplay was blocked. Subtle
     mono label + play icon, centred, with a soft scrim behind so it
     reads on top of any video frame. */
  .hero-play-hint {
    position: absolute;
    left: 50%;
    bottom: 18vh;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-bg);
    background: rgba(20, 20, 24, 0.55);
    border: 1px solid rgba(242, 237, 225, 0.18);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    cursor: pointer;
    z-index: 3;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s var(--ease-out-expo);
  }
  .hero-play-hint[hidden] { display: none; }
  .hero-play-hint.is-visible {
    opacity: 1;
    pointer-events: auto;
    animation: hero-play-pulse 2s ease-in-out infinite;
  }
  .hero-play-hint-icon {
    display: inline-grid;
    place-items: center;
    width: 18px;
    height: 18px;
  }
  .hero-play-hint-icon svg { width: 100%; height: 100%; }

  @keyframes hero-play-pulse {
    0%, 100% { transform: translateX(-50%) scale(1); }
    50%      { transform: translateX(-50%) scale(1.04); }
  }

  /* Cream fade at the bottom edge — 14vh dissolve from transparent to
     the page background so the cinematic dark video transitions into the
     Manifesto cream surface without a hard cut. */
  .hero-veil {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 14vh;
    background: linear-gradient(to bottom, transparent 0%, var(--color-bg) 100%);
    pointer-events: none;
    z-index: 2;
  }

  /* Reduced-motion: hold on the poster, no autoplay loop. */
  @media (prefers-reduced-motion: reduce) {
    .hero-video {
      opacity: 1;
      animation: none;
    }
  }

  @media (max-width: 900px) {
    .hero { height: 100svh; }
    .hero-veil { height: 10vh; }
  }
</style>

<script>
  /* iOS Safari is fussy about autoplay video. The `autoplay muted playsinline`
     attribute set is the documented contract, but Safari sometimes still
     refuses without an explicit `.play()` call once the video is buffered.
     Worse, that play() call returns a Promise that REJECTS silently if the
     OS blocks it (Low Power Mode, Reduce Motion at the OS level, certain
     network conditions). We handle both: try play() on canplay, catch the
     reject, fall back to playing on the first user touch/tap. */
  const video = document.querySelector<HTMLVideoElement>('[data-hero-video]');
  const hint = document.querySelector<HTMLButtonElement>('[data-hero-play-hint]');

  if (video) {
    const reveal = () => video.classList.add('is-ready');
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const showHint = () => {
      if (!hint) return;
      hint.hidden = false;
      // Force a reflow so the transition plays
      requestAnimationFrame(() => hint.classList.add('is-visible'));
    };
    const hideHint = () => {
      if (!hint) return;
      hint.classList.remove('is-visible');
      // Wait for transition to finish before hiding
      setTimeout(() => { hint.hidden = true; }, 400);
    };

    // Hide hint as soon as the video is actually playing
    video.addEventListener('playing', hideHint);

    if (reduced) {
      video.pause();
      video.removeAttribute('autoplay');
      reveal();
    } else {
      const tryPlay = () => {
        const p = video.play();
        if (p && typeof p.then === 'function') {
          p.then(reveal).catch(() => {
            // Autoplay blocked. Show the poster and the tap-to-play hint.
            reveal();
            showHint();
            const startOnTouch = () => {
              video.play().catch(() => {});
              document.removeEventListener('touchstart', startOnTouch);
              document.removeEventListener('click', startOnTouch);
            };
            document.addEventListener('touchstart', startOnTouch, { once: true, passive: true });
            document.addEventListener('click', startOnTouch, { once: true });
          });
        } else {
          reveal();
        }
      };

      if (video.readyState >= 3) {
        tryPlay();
      } else {
        video.addEventListener('canplay', tryPlay, { once: true });
      }
    }

    // Tap the hint itself starts playback
    hint?.addEventListener('click', () => {
      video.play().catch(() => {});
    });
  }
</script>
