---
---
<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <canvas class="hero-silk" data-silk></canvas>
    <div class="hero-glow"></div>
  </div>

  <div class="frame hero-inner">
    <div class="hero-top">
      <span class="eyebrow" data-hero-eyebrow>
        Independent design studio · London
      </span>
      <span class="hero-year font-mono" data-hero-eyebrow>Available Q3 2026</span>
    </div>

    <div class="hero-body" data-tilt3d-parent>
      <h1 class="display-1 reveal-words hero-headline" data-hero-headline data-tilt3d>
        Made to stand out.<br /><em class="italic-accent">Built to stand up.</em>
      </h1>
    </div>

    <div class="hero-foot">
      <p class="lead" data-hero-sub>
        Brand, websites, and social for brands that want to be felt, not just seen.
      </p>
      <div class="hero-ctas" data-hero-ctas>
        <a href="#work" class="btn btn-primary" data-magnetic="0.25">
          See the work <span class="btn-arrow">&rarr;</span>
        </a>
        <a href="#about" class="btn btn-ghost" data-magnetic="0.2">Start a project</a>
      </div>
    </div>

    <div class="hero-scroll-cue" aria-hidden="true">
      <span>scroll</span>
      <span class="hero-scroll-line"></span>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: grid;
    align-items: end;
    padding-top: 120px;
    padding-bottom: clamp(48px, 6vw, 80px);
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .hero-glow {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 75%;
    height: 90%;
    background: radial-gradient(ellipse at 70% 40%, var(--color-ambient) 0%, transparent 55%);
  }

  /* Animated silk canvas — burgundy noise painted directly onto the cream page bg.
     Paints sparse pixels (sample 3) at ~24fps. Earlier versions used a 1.4s opacity
     fade-in via .is-in toggle, but on some devices/browsers the transition stalled
     mid-way and left the layer effectively invisible. The fade was decoration, not
     load-bearing — pinning opacity directly is reliable and visually identical
     once the first frame paints. Hidden entirely under prefers-reduced-motion. */
  .hero-silk {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.65;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-silk { display: none; }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: clamp(32px, 4vw, 64px);
    min-height: calc(100svh - 120px);
    width: 100%;
  }

  .hero-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }
  .hero-year {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }

  .hero-body {
    display: block;
    width: 100%;
    perspective: 1400px;
    perspective-origin: 50% 50%;
    /* Anchor H1 to the top of its zone instead of centering it — the prior
       flex centre layout left ~300px of dead air above the headline on
       full-viewport monitors. Padding-top adds a measured beat below the
       eyebrow row; the 1fr middle row's residual space now sits BELOW the
       headline as breathing room before the lead+CTAs. */
    min-height: clamp(220px, 36vh, 440px);
    display: flex;
    align-items: flex-start;
    padding-top: clamp(24px, 3vw, 56px);
    padding-bottom: clamp(20px, 4vw, 60px);
  }

  .hero-headline {
    transform-style: preserve-3d;
    will-change: transform;
    cursor: grab;
    user-select: none;
    /* subtle double-layer shadow gives the type dimensional weight when it rotates */
    text-shadow:
      0 1px 0 rgba(20, 20, 24, 0.02),
      0 8px 40px rgba(20, 20, 24, 0.06);
  }
  /* Cap line length only at narrow viewports — at desktop the explicit <br>
     in the markup carries the line break, so the prior 20ch cap was redundant
     and made the H1 wrap awkwardly when content was edited. */
  @media (max-width: 720px) {
    .hero-headline { max-width: 18ch; }
  }
  .hero-headline:active { cursor: grabbing; }
  .hero-headline em { font-style: italic; }

  .hero-foot {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
    position: relative;
  }
  /* Vertical rule between the lead (left) and the CTA pair (right) on desktop
     so the wide 1fr gap doesn't read as orphaned columns. */
  @media (min-width: 901px) {
    .hero-foot::after {
      content: "";
      position: absolute;
      top: 32px;
      bottom: 8px;
      right: clamp(140px, 18vw, 220px);
      width: 1px;
      background: var(--color-border);
      opacity: 0.7;
    }
  }
  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .hero-scroll-cue {
    position: absolute;
    right: 0;
    bottom: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
    writing-mode: vertical-rl;
  }
  .hero-scroll-line {
    writing-mode: horizontal-tb;
    display: block;
    width: 1px;
    height: 56px;
    background: linear-gradient(to bottom, var(--color-ink-dim), transparent);
    animation: scroll-pulse 2.4s var(--ease-out-expo) infinite;
  }
  @keyframes scroll-pulse {
    0%, 100% { transform: scaleY(0.5); transform-origin: top; opacity: 0.4; }
    50% { transform: scaleY(1); transform-origin: top; opacity: 1; }
  }

  @media (max-width: 900px) {
    .hero { padding-top: 100px; }
    .hero-body { perspective: 1000px; min-height: auto; padding-block: clamp(32px, 8vw, 80px); }
    .hero-foot {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .hero-scroll-cue { display: none; }
    .hero-ctas {
      width: 100%;
      flex-direction: column;
      gap: 10px;
    }
    .hero-ctas .btn {
      width: 100%;
      justify-content: center;
      padding: 16px 22px;
    }
  }
  @media (max-width: 520px) {
    .hero-top {
      flex-direction: column;
      align-items: flex-start;
      gap: 6px;
      padding-bottom: 6px;
      border-bottom: 1px solid var(--color-border);
    }
    .eyebrow { font-size: 10px; letter-spacing: 0.16em; }
    .hero-headline { max-width: 14ch; }
  }
</style>

<script>
  const canvas = document.querySelector<HTMLCanvasElement>('[data-silk]');
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canvas && !reduced) {
    const ctx = canvas.getContext('2d');
    if (ctx) {
      // Tunables — kept deliberately conservative for CPU budget.
      const SPEED = 0.014;
      const SCALE = 2.4;
      const SAMPLE = 3;             // step (1 of 9 pixels coloured per frame)
      const FPS_CAP = 24;
      const FRAME_MS = 1000 / FPS_CAP;
      // Burgundy ink colour applied via mix-blend-mode: multiply.
      const TINT_R = 139;
      const TINT_G = 30;
      const TINT_B = 42;

      const resize = () => {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      };
      resize();
      window.addEventListener('resize', resize);

      // Cheap noise function from the original (sin-based, no precomputation).
      const noise = (x: number, y: number): number => {
        const G = 2.71828;
        const rx = G * Math.sin(G * x);
        const ry = G * Math.sin(G * y);
        return (rx * ry * (1 + x)) % 1;
      };

      let time = 0;
      let last = 0;

      const tick = (now: number) => {
        if (now - last >= FRAME_MS) {
          last = now;
          const w = canvas.width;
          const h = canvas.height;

          // Reuse a fresh ImageData each frame (transparent base; we paint
          // sparse coloured pixels and let multiply do the tinting).
          const img = ctx.createImageData(w, h);
          const data = img.data;

          const tOffset = SPEED * time;

          for (let x = 0; x < w; x += SAMPLE) {
            for (let y = 0; y < h; y += SAMPLE) {
              const u = (x / w) * SCALE;
              const v = (y / h) * SCALE;
              const tex_x = u;
              const tex_y = v + 0.03 * Math.sin(8 * tex_x - tOffset);

              const pattern = 0.6 + 0.4 * Math.sin(
                5 * (tex_x + tex_y +
                  Math.cos(3 * tex_x + 5 * tex_y) +
                  0.02 * tOffset) +
                Math.sin(20 * (tex_x + tex_y - 0.1 * tOffset)),
              );

              const rnd = noise(x, y);
              const intensity = Math.max(0, pattern - rnd / 18 * 0.8);

              const i = (y * w + x) * 4;
              if (i < data.length) {
                data[i] = TINT_R;
                data[i + 1] = TINT_G;
                data[i + 2] = TINT_B;
                data[i + 3] = Math.min(255, Math.floor(intensity * 230));
              }
            }
          }

          ctx.putImageData(img, 0, 0);
          time += 1;
        }
        requestAnimationFrame(tick);
      };

      requestAnimationFrame(tick);
    }
  }
</script>
