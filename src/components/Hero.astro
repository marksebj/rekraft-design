---
---
<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-grain"></div>
    <div class="hero-glow"></div>
  </div>

  <div class="frame hero-inner">
    <div class="hero-top">
      <span class="eyebrow" data-hero-eyebrow>
        Independent design studio · London
      </span>
      <span class="hero-year font-mono" data-hero-eyebrow>Est. 2026</span>
    </div>

    <div class="hero-body">
      <h1 class="display-1 reveal-words" data-hero-headline>
        Made to stand out.<br /><em class="italic-accent">Built to stand up.</em>
      </h1>

      <aside class="hero-tile" aria-hidden="true">
        <div class="hero-tile-mark">
          <span class="hero-tile-mark-top font-mono">studio</span>
          <span class="hero-tile-mark-word font-display">design</span>
          <span class="hero-tile-mark-bottom font-mono">— est. 2026</span>
        </div>
      </aside>
    </div>

    <div class="hero-foot">
      <p class="lead" data-hero-sub>
        Brand, websites, and social for brands that mean business.
      </p>
      <div class="hero-ctas" data-hero-ctas>
        <a href="#work" class="btn btn-primary" data-magnetic="0.25">
          See the work <span class="btn-arrow">&rarr;</span>
        </a>
        <a href="#contact" class="btn btn-ghost" data-magnetic="0.2">Start a project</a>
      </div>
    </div>

    <div class="hero-scroll-cue" aria-hidden="true">
      <span>scroll</span>
      <span class="hero-scroll-line"></span>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: grid;
    align-items: end;
    padding-top: 120px;
    padding-bottom: clamp(48px, 6vw, 80px);
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .hero-glow {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 75%;
    height: 90%;
    background: radial-gradient(ellipse at 70% 40%, var(--color-ambient) 0%, transparent 55%);
  }
  .hero-grain {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 1px 1px, rgba(20, 20, 24, 0.06) 1px, transparent 0);
    background-size: 3px 3px;
    opacity: 0.55;
    mix-blend-mode: multiply;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: clamp(32px, 4vw, 64px);
    min-height: calc(100svh - 120px);
    width: 100%;
  }

  .hero-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }
  .hero-year {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }

  .hero-body {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: clamp(32px, 4vw, 80px);
    width: 100%;
  }

  .hero h1 {
    max-width: 18ch;
    margin-top: clamp(20px, 4vw, 60px);
  }
  .hero h1 em { font-style: italic; }

  .hero-tile {
    width: clamp(220px, 22vw, 340px);
    display: grid;
    gap: 12px;
    align-self: end;
    margin-bottom: 4px;
  }
  .hero-tile-mark {
    aspect-ratio: 4 / 5;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    box-shadow: 0 12px 40px -20px rgba(20, 20, 24, 0.35);
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: 24px;
    overflow: hidden;
    position: relative;
  }
  .hero-tile-mark::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 20%, var(--color-ambient) 0%, transparent 55%),
      linear-gradient(180deg, transparent 0%, rgba(139, 30, 42, 0.04) 100%);
    pointer-events: none;
  }
  .hero-tile-mark-top,
  .hero-tile-mark-bottom {
    position: relative;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }
  .hero-tile-mark-top { color: var(--color-cream); }
  .hero-tile-mark-word {
    position: relative;
    align-self: center;
    justify-self: center;
    font-style: italic;
    font-size: clamp(56px, 8vw, 120px);
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: var(--color-cream);
    text-align: center;
    transform: translateY(-4%);
    transition: transform 1.2s var(--ease-out-expo);
  }
  .hero-tile-mark:hover .hero-tile-mark-word {
    transform: translateY(-8%) rotate(-1.5deg);
  }
  .hero-tile-mark-bottom { text-align: right; }

  .hero-foot {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }
  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .hero-scroll-cue {
    position: absolute;
    right: 0;
    bottom: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
    writing-mode: vertical-rl;
  }
  .hero-scroll-line {
    writing-mode: horizontal-tb;
    display: block;
    width: 1px;
    height: 56px;
    background: linear-gradient(to bottom, var(--color-ink-dim), transparent);
    animation: scroll-pulse 2.4s var(--ease-out-expo) infinite;
  }
  @keyframes scroll-pulse {
    0%, 100% { transform: scaleY(0.5); transform-origin: top; opacity: 0.4; }
    50% { transform: scaleY(1); transform-origin: top; opacity: 1; }
  }

  @media (max-width: 1100px) {
    .hero-body { grid-template-columns: 1fr; gap: 24px; }
    .hero-tile { justify-self: start; width: min(300px, 70%); }
  }
  @media (max-width: 900px) {
    .hero { padding-top: 100px; }
    .hero-foot {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .hero-scroll-cue { display: none; }
  }
  @media (max-width: 520px) {
    .hero-top { flex-direction: column; align-items: flex-start; gap: 8px; }
    .hero-tile { display: none; }
  }
</style>
