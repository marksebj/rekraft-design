---
const cases = [
  {
    num: '01',
    tag: 'B · Editorial',
    title: 'Aesthetic Clinic',
    meta: 'Brand · Website · Social · 2026',
    description: 'Identity and launch site for a London clinic. Soft, editorial, built to earn trust.',
    status: 'In production',
    image: 'https://images.unsplash.com/photo-1616394584738-fc6e612e71b9?auto=format&fit=crop&w=1600&q=80',
    featured: true,
  },
  {
    num: '02',
    tag: 'A · Cinematic',
    title: 'Kinetic Film Studio',
    meta: 'Brand · Website · 2026',
    description: 'A fully interactive site for a film production company. WebGL, scroll-driven, bold.',
    status: 'Showcase',
    image: 'https://images.unsplash.com/photo-1478720568477-152d9b164e26?auto=format&fit=crop&w=1200&q=80',
  },
  {
    num: '03',
    tag: 'C · Brand-forward',
    title: 'Live Life Customs',
    meta: 'Brand · Website · 2026',
    description: 'Streetwear brand revival. Bold visual system, custom apparel portfolio, Instagram-only intake.',
    status: 'Live',
    image: '/images/work/llc/04-nasa.jpg',
    href: '/work/livelifecustoms',
  },
  {
    num: '04',
    tag: 'Next',
    title: 'Your brand, here',
    meta: 'Taking Q3 2026 bookings',
    description: 'Small roster. If you have something serious to build, let&rsquo;s talk.',
    status: 'Open slot',
    image: '',
    isOpenSlot: true,
  },
];
---

<section id="work" class="section work">
  <div class="frame">
    <header class="work-head">
      <div class="work-head-left">
        <span class="eyebrow">01 &middot; Selected Work</span>
        <h2 class="display-2 reveal-words" data-reveal-headline>
          The work speaks <em class="italic-accent">for itself.</em>
        </h2>
      </div>
      <p class="lead fade-up work-head-lead">
        Small roster. Every project built properly.
      </p>
    </header>

    <div class="work-grid">
      {cases.map((c, i) => (
        <a href={c.href ?? '#contact'} class={`work-card fade-up ${c.featured ? 'is-featured' : ''} ${c.isOpenSlot ? 'is-open' : ''}`}>
          <div
            class="work-card-media"
            data-tilt3d-parent
            data-tilt3d-wobble
            data-tilt-y="7"
            data-tilt-x="5"
            data-tilt-pull="0.008"
            data-wobble-phase={i}
          >
            <div class="work-card-media-inner" data-tilt3d>
              {c.image && (
                <img
                  class="work-card-img"
                  src={c.image}
                  alt=""
                  loading="lazy"
                  decoding="async"
                />
              )}
              <div class="work-card-overlay"></div>
              {c.isOpenSlot && (
                <div class="work-card-openmark font-display">+</div>
              )}
            </div>
            <div class="work-card-num font-mono">{c.num}</div>
            <div class="work-card-status font-mono">{c.status}</div>
          </div>
          <div class="work-card-info">
            <div class="work-card-tag font-mono">{c.tag}</div>
            <h3 class="display-3">{c.title}</h3>
            <div class="work-card-meta font-mono">{c.meta}</div>
            <p class="work-card-desc" set:html={c.description}></p>
            <div class="work-card-arrow">
              <span>View</span>
              <span class="btn-arrow">&rarr;</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .work {
    padding-top: clamp(100px, 12vw, 200px);
    padding-bottom: clamp(80px, 10vw, 160px);
  }

  .work-head {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: clamp(40px, 6vw, 120px);
    align-items: end;
    margin-bottom: clamp(48px, 6vw, 96px);
  }
  .work-head-left { display: grid; gap: 20px; }
  .work-head-lead { margin-bottom: 8px; }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(24px, 3vw, 48px);
  }
  .work-card.is-featured { grid-column: 1 / -1; }

  .work-card {
    display: grid;
    grid-template-rows: auto auto;
    gap: 24px;
    transition: transform .6s var(--ease-out-expo);
  }
  .work-card:hover { transform: translateY(-6px); }

  .work-card-media {
    aspect-ratio: 4 / 5;
    border-radius: 14px;
    position: relative;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    transition: border-color .5s var(--ease-out-expo);
    box-shadow: 0 20px 60px -30px rgba(20, 20, 24, 0.4);
    /* 3D container for the inner card */
    perspective: 1200px;
    perspective-origin: 50% 50%;
  }
  .work-card.is-featured .work-card-media { aspect-ratio: 21 / 9; }
  .work-card:hover .work-card-media { border-color: var(--color-border-active); }

  .work-card-media-inner {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    overflow: hidden;
    transform-style: preserve-3d;
    will-change: transform;
  }

  .work-card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: contrast(1.04) saturate(0.92);
    transition: transform 8s var(--ease-out-expo);
  }
  .work-card:hover .work-card-img { transform: scale(1.04); }

  .work-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(20, 20, 24, 0.15) 0%, rgba(20, 20, 24, 0.0) 35%, rgba(20, 20, 24, 0.0) 60%, rgba(20, 20, 24, 0.55) 100%);
    pointer-events: none;
  }

  .work-card-num {
    position: absolute;
    top: 20px;
    left: 24px;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: #F5F0E5;
    opacity: 0.9;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.4);
  }
  .work-card-status {
    position: absolute;
    top: 20px;
    right: 24px;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #F5F0E5;
    padding: 6px 12px;
    border: 1px solid rgba(245, 240, 229, 0.4);
    border-radius: 999px;
    background: rgba(20, 20, 24, 0.35);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  /* Open slot, dashed outline, cream bg, big plus mark */
  .work-card.is-open .work-card-media {
    border-style: dashed;
    border-color: var(--color-border-active);
    background: var(--color-surface);
    box-shadow: none;
  }
  .work-card.is-open .work-card-media-inner {
    display: grid;
    place-items: center;
  }
  .work-card.is-open .work-card-img { display: none; }
  .work-card.is-open .work-card-overlay { display: none; }
  .work-card.is-open .work-card-num,
  .work-card.is-open .work-card-status {
    color: var(--color-ink-dim);
    text-shadow: none;
    background: transparent;
    border-color: var(--color-border-active);
  }
  .work-card-openmark {
    font-size: clamp(72px, 10vw, 160px);
    line-height: 1;
    color: var(--color-ink-faint);
    font-weight: 400;
    user-select: none;
    transition: color .4s var(--ease-out-expo), transform .6s var(--ease-out-expo);
  }
  .work-card.is-open:hover .work-card-openmark {
    color: var(--color-cream);
    transform: rotate(90deg);
  }

  .work-card-info {
    display: grid;
    gap: 14px;
    padding: 0 4px;
  }
  .work-card-tag {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-cream);
  }
  .work-card h3 {
    font-size: clamp(28px, 3.2vw, 52px);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--color-ink);
  }
  .work-card-meta {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }
  .work-card-desc {
    font-family: var(--font-sans);
    font-size: clamp(14px, 0.4vw + 12px, 16px);
    line-height: 1.65;
    color: var(--color-ink-muted);
    max-width: 52ch;
  }
  .work-card-arrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink);
    margin-top: 6px;
  }
  .work-card:hover .work-card-arrow .btn-arrow { transform: translateX(6px); }
  .work-card-arrow .btn-arrow { transition: transform .4s var(--ease-out-expo); }

  @media (max-width: 900px) {
    .work-head { grid-template-columns: 1fr; gap: 28px; }
    .work-grid { grid-template-columns: 1fr; }
    .work-card.is-featured .work-card-media { aspect-ratio: 4 / 5; }
  }
</style>
