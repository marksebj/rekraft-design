---
const tiers = [
  {
    name: 'Discovery',
    price: 'Free',
    priceTagline: '30-minute call · No commitment',
    description: 'A quick call to talk through what you’re building. We share an honest take and point you somewhere better if we’re not the right fit.',
    features: [
      '30-minute call, no commitment',
      'Quick once-over of what you have',
      'Honest take on whether we’re a fit',
      'Project recommendation if we are',
    ],
    cta: 'Book the call',
    ctaUrl: 'mailto:mark@rekraft.design?subject=Discovery%20call',
    flagship: false,
  },
  {
    name: 'Website',
    price: 'From £1,250',
    priceTagline: 'Bespoke build · 2 to 3 weeks',
    description: 'Custom-built site. Strategy, design, motion, launch. Never themed.',
    features: [
      'Strategy and structure',
      'Bespoke design pass with one revision round',
      'Custom build (Astro or Webflow)',
      'Launch, handover, training video',
    ],
    cta: 'Book a call',
    ctaUrl: 'mailto:mark@rekraft.design?subject=Website%20enquiry',
    flagship: true,
    badge: 'Most requested',
  },
  {
    name: 'Brand + Site',
    price: 'From £2,450',
    priceTagline: 'Brand kit + bespoke site · 3 to 4 weeks',
    description: 'Brand identity and website, built together. Everything ships aligned.',
    features: [
      'Brand kit: mark, type, palette, mini-guidelines',
      'Bespoke website with motion',
      'Launch creative: 6 social templates',
      'Photography and copy direction',
    ],
    cta: 'Book a call',
    ctaUrl: 'mailto:mark@rekraft.design?subject=Brand%20%2B%20Site%20enquiry',
    flagship: false,
  },
];
---

<section id="investment" class="section invest">
  <div class="frame">
    <header class="invest-head">
      <span class="eyebrow">03 &middot; Pricing</span>
      <h2 class="display-2 reveal-words" data-reveal-headline>
        Three ways in. <em class="italic-accent">Bespoke from there.</em>
      </h2>
    </header>

    <div class="invest-grid">
      {tiers.map((t) => (
        <article class={`invest-card fade-up${t.flagship ? ' is-flagship' : ''}`}>
          {t.flagship && <span class="invest-badge font-mono">{t.badge}</span>}
          <header class="invest-card-head">
            <h3 class="invest-card-name">{t.name}</h3>
            <div class="invest-card-price-block">
              <span class="invest-card-price font-display">{t.price}</span>
              <span class="invest-card-price-tag font-mono">{t.priceTagline}</span>
            </div>
          </header>
          <p class="invest-card-desc">{t.description}</p>
          <ul class="invest-card-features">
            {t.features.map((f) => (
              <li class="invest-card-feature">
                <span class="invest-card-feature-dot" aria-hidden="true"></span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <a
            href={t.ctaUrl}
            class={`btn ${t.flagship ? 'btn-primary' : 'btn-ghost'} invest-card-cta`}
          >
            {t.cta} <span class="btn-arrow">&rarr;</span>
          </a>
        </article>
      ))}
    </div>

    <article class="invest-custom fade-up">
      <div class="invest-custom-content">
        <span class="invest-custom-eyebrow font-mono">Something else</span>
        <h3 class="invest-custom-title">Want something custom?</h3>
        <p class="invest-custom-desc">
          Retainers from £150/mo for hosting and small changes, or £450/mo for ongoing creative output. Brand-only work, motion polish, photography days, copywriting, performance audits. Anything that doesn't fit a tier. Tell us what you're building and we'll scope it honestly.
        </p>
      </div>
      <a href="mailto:mark@rekraft.design?subject=Bespoke%20Project" class="btn btn-primary invest-custom-cta">
        Start a conversation <span class="btn-arrow">&rarr;</span>
      </a>
    </article>

    <p class="invest-foot fade-up">
      All numbers exclude VAT. Bespoke work is quoted to scope; the figures above are honest starting points. We take on a small number of projects each quarter.
    </p>
  </div>
</section>

<style>
  .invest {
    border-top: 1px solid var(--color-border);
    padding-block: clamp(56px, 6vw, 96px);
  }

  .invest-head {
    display: grid;
    gap: 14px;
    max-width: 720px;
    margin-bottom: clamp(36px, 4vw, 56px);
  }

  /* Three-card pricing grid */
  .invest-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 2vw, 28px);
    margin-bottom: clamp(28px, 3vw, 40px);
  }

  .invest-card {
    position: relative;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: clamp(28px, 2.6vw + 8px, 40px);
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition:
      transform 0.4s var(--ease-out-expo),
      border-color 0.4s var(--ease-out-expo),
      box-shadow 0.4s var(--ease-out-expo);
  }
  .invest-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-border-active);
    box-shadow: 0 24px 60px -32px rgba(20, 20, 24, 0.28);
  }
  .invest-card.is-flagship {
    border-color: var(--color-border-active);
    box-shadow: 0 18px 50px -34px rgba(20, 20, 24, 0.22);
  }
  .invest-card.is-flagship:hover {
    box-shadow: 0 28px 70px -32px rgba(20, 20, 24, 0.34);
  }

  .invest-badge {
    position: absolute;
    top: 18px;
    right: 20px;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-lime);
    padding: 5px 10px;
    border: 1px solid var(--color-lime);
    border-radius: 999px;
    background: var(--color-lime-soft);
  }

  /* Card head: name + price */
  .invest-card-head {
    display: grid;
    gap: 14px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--color-border);
  }
  .invest-card-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(24px, 1.6vw + 10px, 32px);
    line-height: 1;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    padding-bottom: 0.04em;
  }
  .invest-card-price-block {
    display: grid;
    gap: 4px;
  }
  .invest-card-price {
    font-size: clamp(36px, 3.2vw, 56px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    padding-bottom: 0.06em;
  }
  .invest-card-price-tag {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
    line-height: 1.4;
  }

  .invest-card-desc {
    font-size: clamp(14px, 0.3vw + 12px, 15px);
    line-height: 1.6;
    color: var(--color-ink-muted);
    max-width: 38ch;
  }

  .invest-card-features {
    list-style: none;
    display: grid;
    gap: 10px;
    padding-top: 8px;
    margin-top: auto;
  }
  .invest-card-feature {
    display: grid;
    grid-template-columns: 16px 1fr;
    align-items: start;
    gap: 12px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-ink-muted);
  }
  .invest-card-feature-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-lime);
    margin-top: 7px;
    margin-left: 4px;
  }

  .invest-card-cta {
    margin-top: 4px;
    justify-content: center;
    width: 100%;
  }

  /* Custom Request card — full-width, cream surface */
  .invest-custom {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(24px, 4vw, 60px);
    align-items: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: clamp(28px, 3vw, 44px);
  }
  .invest-custom-content {
    display: grid;
    gap: 10px;
    max-width: 64ch;
  }
  .invest-custom-eyebrow {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }
  .invest-custom-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(24px, 1.6vw + 10px, 32px);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    padding-bottom: 0.04em;
  }
  .invest-custom-desc {
    font-size: clamp(14px, 0.3vw + 12px, 15px);
    line-height: 1.6;
    color: var(--color-ink-muted);
  }
  .invest-custom-cta { justify-self: start; }

  .invest-foot {
    font-family: var(--font-sans);
    font-size: 12px;
    line-height: 1.6;
    color: var(--color-ink-dim);
    max-width: 64ch;
    margin-top: clamp(24px, 3vw, 36px);
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 1000px) {
    .invest-grid { grid-template-columns: 1fr; }
    .invest-custom { grid-template-columns: 1fr; gap: 20px; }
  }
</style>
