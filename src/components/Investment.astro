---

<section id="investment" class="section invest">
  <div class="frame">
    <header class="invest-head">
      <span class="eyebrow">03 &middot; Pricing</span>
      <h2 class="display-2 reveal-words" data-reveal-headline>
        Three ways in. <em class="italic-accent">Bespoke from there.</em>
      </h2>
    </header>

    <div class="invest-tabs fade-up" role="tablist" aria-label="Pricing type">
      {tabs.map((tab, i) => (
        <button
          class={`invest-tab${i === 0 ? ' is-active' : ''}`}
          data-tab={tab.id}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          type="button"
        >
          {tab.label}
        </button>
      ))}
    </div>

    <div class="invest-group is-active" data-group="oneoff" role="tabpanel">
      <div class="invest-grid invest-grid-3">
        {oneoffTiers.map((t, i) => (
          <article
            class={`invest-card fade-up${t.flagship ? ' is-flagship' : ''}`}
            style={`--reveal-delay: ${i * 0.12}s`}
          >
            {t.flagship && <span class="invest-badge font-mono">{t.badge}</span>}
            <header class="invest-card-head">
              <h3 class="invest-card-name">{t.name}</h3>
              <div class="invest-card-price-block">
                <span class="invest-card-price font-display">{t.price}</span>
                <span class="invest-card-price-tag font-mono">{t.priceTagline}</span>
              </div>
            </header>
            <p class="invest-card-desc">{t.description}</p>
            <ul class="invest-card-features">
              {t.features.map((f) => (
                <li class="invest-card-feature">
                  <span class="invest-card-feature-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[f.icon]}></svg>
                  </span>
                  <span class="invest-card-feature-label">{f.label}</span>
                </li>
              ))}
            </ul>
            <a
              href={t.ctaUrl}
              class={`btn ${t.flagship ? 'btn-primary' : 'btn-ghost'} invest-card-cta`}
            >
              {t.cta} <span class="btn-arrow">&rarr;</span>
            </a>
          </article>
        ))}
      </div>
    </div>

    <div class="invest-group" data-group="retainer" role="tabpanel">
      <div class="invest-grid invest-grid-3">
        {retainerTiers.map((t, i) => (
          <article
            class={`invest-card fade-up${t.flagship ? ' is-flagship' : ''}`}
            style={`--reveal-delay: ${i * 0.12}s`}
          >
            {t.flagship && <span class="invest-badge font-mono">{t.badge}</span>}
            <header class="invest-card-head">
              <h3 class="invest-card-name">{t.name}</h3>
              <div class="invest-card-price-block">
                <span class="invest-card-price font-display">
                  {t.price}<span class="invest-card-price-suffix font-sans">{t.priceSuffix}</span>
                </span>
                <span class="invest-card-price-tag font-mono">{t.priceTagline}</span>
              </div>
            </header>
            <p class="invest-card-desc">{t.description}</p>
            <ul class="invest-card-features">
              {t.features.map((f) => (
                <li class="invest-card-feature">
                  <span class="invest-card-feature-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[f.icon]}></svg>
                  </span>
                  <span class="invest-card-feature-label">{f.label}</span>
                </li>
              ))}
            </ul>
            <a
              href={t.ctaUrl}
              class={`btn ${t.flagship ? 'btn-primary' : 'btn-ghost'} invest-card-cta`}
            >
              {t.cta} <span class="btn-arrow">&rarr;</span>
            </a>
          </article>
        ))}
      </div>
    </div>

    <details class="invest-addons fade-up">
      <summary class="invest-addons-summary">
        <div class="invest-addons-summary-content">
          <span class="invest-addons-eyebrow font-mono">Add-ons</span>
          <span class="invest-addons-title">Bolt anything onto a tier or a retainer.</span>
        </div>
        <span class="invest-addons-toggle font-mono" aria-hidden="true">+</span>
      </summary>
      <ol class="invest-addons-list">
        {addons.map((a) => (
          <li class="invest-addon">
            <div class="invest-addon-head">
              <h4 class="invest-addon-name">{a.name}</h4>
              <span class="invest-addon-price font-mono">{a.price}</span>
            </div>
            <p class="invest-addon-desc">{a.description}</p>
          </li>
        ))}
      </ol>
    </details>

    <article class="invest-custom fade-up">
      <div class="invest-custom-content">
        <span class="invest-custom-eyebrow font-mono">Something else</span>
        <h3 class="invest-custom-title">Or something else entirely.</h3>
        <p class="invest-custom-close">
          Anything that doesn&rsquo;t fit a tier or an add-on. Tell us what you&rsquo;re building and we&rsquo;ll scope it honestly.
        </p>
      </div>
      <a href="mailto:mark@rekraft.design?subject=Bespoke%20Project" class="btn btn-primary invest-custom-cta">
        Start a conversation <span class="btn-arrow">&rarr;</span>
      </a>
    </article>

    <p class="invest-foot fade-up">
      All numbers exclude VAT. Bespoke work is quoted to scope; the figures above are honest starting points. We take on a small number of projects each quarter.
    </p>
  </div>
</section>

<style>
  .invest {
    border-top: 1px solid var(--color-border);
    padding-block: clamp(56px, 6vw, 96px);
  }

  .invest-head {
    display: grid;
    gap: 14px;
    max-width: 720px;
    margin-bottom: clamp(28px, 3vw, 40px);
  }

  /* Tab toggle pill */
  .invest-tabs {
    display: inline-flex;
    gap: 4px;
    padding: 4px;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-card);
    margin-bottom: clamp(28px, 3vw, 40px);
  }
  .invest-tab {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
    padding: 10px 22px;
    border-radius: 999px;
    transition: color 0.35s var(--ease-out-expo), background 0.35s var(--ease-out-expo);
    cursor: pointer;
  }
  .invest-tab:hover { color: var(--color-ink); }
  .invest-tab.is-active {
    color: var(--color-bg);
    background: var(--color-ink);
  }

  /* Card groups (one per tab) */
  .invest-group {
    display: none;
    margin-bottom: clamp(28px, 3vw, 40px);
  }
  .invest-group.is-active { display: block; }

  /* Pricing grids */
  .invest-grid {
    display: grid;
    gap: clamp(20px, 2vw, 28px);
  }
  .invest-grid-3 { grid-template-columns: repeat(3, 1fr); }
  .invest-grid-2 {
    grid-template-columns: repeat(2, 1fr);
    max-width: 800px;
  }

  .invest-card {
    position: relative;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: clamp(28px, 2.6vw + 8px, 40px);
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition:
      opacity 0.25s var(--ease-out-expo),
      transform 0.25s var(--ease-out-expo),
      border-color 0.25s var(--ease-out-expo),
      box-shadow 0.25s var(--ease-out-expo);
  }

  /* Entry stagger — slower transition for the reveal-on-scroll moment */
  .invest-card.fade-up.is-in {
    transition:
      opacity 0.9s var(--ease-out-expo) var(--reveal-delay, 0s),
      transform 0.9s var(--ease-out-expo) var(--reveal-delay, 0s);
  }

  /* Hover focus: dim siblings within the same grid */
  .invest-grid:hover .invest-card:not(:hover) {
    opacity: 0.5;
    transform: scale(0.97);
  }

  .invest-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-border-active);
    box-shadow: 0 24px 60px -32px rgba(20, 20, 24, 0.28);
  }
  .invest-card.is-flagship {
    border-color: var(--color-border-active);
    box-shadow: 0 18px 50px -34px rgba(20, 20, 24, 0.22);
  }
  .invest-card.is-flagship:hover {
    box-shadow: 0 28px 70px -32px rgba(20, 20, 24, 0.34);
  }

  @media (prefers-reduced-motion: reduce) {
    .invest-grid:hover .invest-card:not(:hover) {
      opacity: 1;
      transform: none;
    }
  }

  .invest-badge {
    position: absolute;
    top: 18px;
    right: 20px;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-lime);
    padding: 5px 10px;
    border: 1px solid var(--color-lime);
    border-radius: 999px;
    background: var(--color-lime-soft);
  }

  .invest-card-head {
    display: grid;
    gap: 14px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--color-border);
  }
  .invest-card-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(24px, 1.6vw + 10px, 32px);
    line-height: 1;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    padding-bottom: 0.04em;
  }
  .invest-card-price-block { display: grid; gap: 4px; }
  .invest-card-price {
    font-size: clamp(36px, 3.2vw, 56px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    padding-bottom: 0.06em;
  }
  .invest-card-price-suffix {
    font-size: 16px;
    color: var(--color-ink-dim);
    letter-spacing: 0.01em;
    margin-left: 4px;
    font-weight: 400;
  }
  .invest-card-price-tag {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
    line-height: 1.4;
  }

  .invest-card-desc {
    font-size: clamp(14px, 0.3vw + 12px, 15px);
    line-height: 1.6;
    color: var(--color-ink-muted);
    max-width: 38ch;
  }

  /* Feature grid — 2x2 of icon-and-label pairs (graphics doing the talking). */
  .invest-card-features {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px 12px;
    padding-top: 14px;
    margin-top: auto;
    border-top: 1px solid var(--color-border);
  }
  .invest-card-feature {
    display: grid;
    gap: 8px;
    align-content: start;
  }
  .invest-card-feature-icon {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-lime-soft);
    color: var(--color-lime);
    display: grid;
    place-items: center;
    transition: background 0.3s var(--ease-out-expo), color 0.3s var(--ease-out-expo);
  }
  .invest-card-feature-icon svg {
    width: 14px;
    height: 14px;
  }
  .invest-card:hover .invest-card-feature-icon {
    background: var(--color-lime);
    color: var(--color-bg);
  }
  .invest-card-feature-label {
    font-size: 12px;
    line-height: 1.35;
    color: var(--color-ink-muted);
    letter-spacing: -0.005em;
  }

  .invest-card-cta {
    margin-top: 4px;
    justify-content: center;
    width: 100%;
  }

  /* Add-ons accordion (collapsed by default) */
  .invest-addons {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    margin-bottom: clamp(20px, 2vw, 32px);
    overflow: hidden;
    transition: border-color 0.3s var(--ease-out-expo);
  }
  .invest-addons[open] {
    border-color: var(--color-border-active);
  }
  .invest-addons-summary {
    list-style: none;
    cursor: pointer;
    padding: clamp(20px, 2vw, 28px) clamp(24px, 3vw, 36px);
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: clamp(16px, 2vw, 32px);
    transition: background 0.3s var(--ease-out-expo);
  }
  .invest-addons-summary::-webkit-details-marker { display: none; }
  .invest-addons-summary:hover { background: var(--color-card-hover); }

  .invest-addons-summary-content {
    display: grid;
    gap: 6px;
  }
  .invest-addons-eyebrow {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }
  .invest-addons-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(20px, 1.2vw + 8px, 26px);
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--color-ink);
  }
  .invest-addons-toggle {
    width: 32px;
    height: 32px;
    border: 1px solid var(--color-border-active);
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 14px;
    color: var(--color-ink);
    transition: transform 0.3s var(--ease-out-expo), background 0.3s var(--ease-out-expo), color 0.3s var(--ease-out-expo);
  }
  .invest-addons[open] .invest-addons-toggle {
    background: var(--color-ink);
    color: var(--color-bg);
    border-color: var(--color-ink);
    transform: rotate(45deg);
  }

  .invest-addons-list {
    list-style: none;
    border-top: 1px solid var(--color-border);
    display: grid;
  }
  .invest-addon {
