<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.invest-tab');
  const groups = document.querySelectorAll<HTMLElement>('.invest-group');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach((t) => {
        const isActive = t === tab;
        t.classList.toggle('is-active', isActive);
        t.setAttribute('aria-selected', String(isActive));
      });
      groups.forEach((g) => {
        const isActive = g.dataset.group === target;
        g.classList.toggle('is-active', isActive);
        if (isActive) {
          // Force reveal on cards inside the newly visible group, in case
          // the global ScrollTrigger/IntersectionObserver hasn't fired for them
          // (they were display:none on initial load).
          g.querySelectorAll<HTMLElement>('.fade-up').forEach((el) => el.classList.add('is-in'));
        }
      });
    });
  });
</script>
