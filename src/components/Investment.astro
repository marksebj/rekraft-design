---
const oneoffTiers = [
  {
    name: 'Discovery',
    price: 'Free',
    priceTagline: '30-minute call · No commitment',
    description: 'A quick call to talk through what you’re building. We share an honest take and point you somewhere better if we’re not the right fit.',
    features: [
      '30-minute call, no commitment',
      'Quick once-over of what you have',
      'Honest take on whether we’re a fit',
      'Project recommendation if we are',
    ],
    cta: 'Book the call',
    ctaUrl: 'mailto:mark@rekraft.design?subject=Discovery%20call',
    flagship: false,
  },
  {
    name: 'Website',
    price: 'From £950',
    priceTagline: 'Bespoke build · 2 to 3 weeks',
    description: 'Custom-built site. Strategy, design, motion, launch. Never themed.',
    features: [
      'Strategy and structure',
      'Bespoke design pass with one revision round',
      'Custom build (Astro or Webflow)',
      'Launch, handover, training video',
    ],
    cta: 'Book a call',
    ctaUrl: 'mailto:mark@rekraft.design?subject=Website%20enquiry',
    flagship: true,
    badge: 'Most requested',
  },
  {
    name: 'Brand + Site',
    price: 'From £2,450',
    priceTagline: 'Brand kit + bespoke site · 3 to 4 weeks',
    description: 'Brand identity and website, built together. Everything ships aligned.',
    features: [
      'Brand kit: mark, type, palette, mini-guidelines',
      'Bespoke website with motion',
      'Launch creative: 6 social templates',
      'Photography and copy direction',
    ],
    cta: 'Book a call',
    ctaUrl: 'mailto:mark@rekraft.design?subject=Brand%20%2B%20Site%20enquiry',
    flagship: false,
  },
];

const retainerTiers = [
  {
    name: 'Maintain',
    price: 'From £150',
    priceSuffix: '/mo',
    priceTagline: 'Monthly · 14 days notice',
    description: 'Keep your site healthy. Hosting, monitoring, small change requests, performance reviews. Email support.',
    features: [
      'Hosting and uptime monitoring',
      'Small change requests',
      'Performance reviews',
      'Email support',
    ],
    cta: 'Talk retainer',
    ctaUrl: 'mailto:mark@rekraft.design?subject=Maintain%20retainer',
    flagship: false,
  },
  {
    name: 'Evolve',
    price: 'From £300',
    priceSuffix: '/mo',
    priceTagline: 'Monthly · 14 days notice',
    description: 'Maintain plus ongoing creative output. Quarterly strategy reviews, content systems.',
    features: [
      'Everything in Maintain',
      'Ongoing creative output',
      'Quarterly strategy review',
      'Priority email + Slack',
    ],
    cta: 'Talk retainer',
    ctaUrl: 'mailto:mark@rekraft.design?subject=Evolve%20retainer',
    flagship: false,
  },
  {
    name: 'Amplify',
    price: 'From £550',
    priceSuffix: '/mo',
    priceTagline: 'Monthly · 14 days notice',
    description: 'Full creative partnership. Brand stewardship, monthly direction, photography quarterly, direct line.',
    features: [
      'Everything in Evolve',
      'Monthly creative direction',
      'Quarterly photography day',
      'Direct WhatsApp · same-day response',
    ],
    cta: 'Talk retainer',
    ctaUrl: 'mailto:mark@rekraft.design?subject=Amplify%20retainer',
    flagship: false,
  },
];

const tabs = [
  { id: 'oneoff', label: 'One-off' },
  { id: 'retainer', label: 'Retainer' },
];
---

<section id="investment" class="section invest">
  <div class="frame">
    <header class="invest-head">
      <span class="eyebrow">03 &middot; Pricing</span>
      <h2 class="display-2 reveal-words" data-reveal-headline>
        Three ways in. <em class="italic-accent">Bespoke from there.</em>
      </h2>
    </header>

    <div class="invest-tabs fade-up" role="tablist" aria-label="Pricing type">
      {tabs.map((tab, i) => (
        <button
          class={`invest-tab${i === 0 ? ' is-active' : ''}`}
          data-tab={tab.id}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          type="button"
        >
          {tab.label}
        </button>
      ))}
    </div>

    <div class="invest-group is-active" data-group="oneoff" role="tabpanel">
      <div class="invest-grid invest-grid-3">
        {oneoffTiers.map((t, i) => (
          <article
            class={`invest-card fade-up${t.flagship ? ' is-flagship' : ''}`}
            style={`--reveal-delay: ${i * 0.12}s`}
          >
            {t.flagship && <span class="invest-badge font-mono">{t.badge}</span>}
            <header class="invest-card-head">
              <h3 class="invest-card-name">{t.name}</h3>
              <div class="invest-card-price-block">
                <span class="invest-card-price font-display">{t.price}</span>
                <span class="invest-card-price-tag font-mono">{t.priceTagline}</span>
              </div>
            </header>
            <p class="invest-card-desc">{t.description}</p>
            <ul class="invest-card-features">
              {t.features.map((f) => (
                <li class="invest-card-feature">
                  <span class="invest-card-feature-dot" aria-hidden="true"></span>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
            <a
              href={t.ctaUrl}
              class={`btn ${t.flagship ? 'btn-primary' : 'btn-ghost'} invest-card-cta`}
            >
              {t.cta} <span class="btn-arrow">&rarr;</span>
            </a>
          </article>
        ))}
      </div>
    </div>

    <div class="invest-group" data-group="retainer" role="tabpanel">
      <div class="invest-grid invest-grid-3">
        {retainerTiers.map((t, i) => (
          <article
            class={`invest-card fade-up${t.flagship ? ' is-flagship' : ''}`}
            style={`--reveal-delay: ${i * 0.12}s`}
          >
            {t.flagship && <span class="invest-badge font-mono">{t.badge}</span>}
            <header class="invest-card-head">
              <h3 class="invest-card-name">{t.name}</h3>
              <div class="invest-card-price-block">
                <span class="invest-card-price font-display">
                  {t.price}<span class="invest-card-price-suffix font-sans">{t.priceSuffix}</span>
                </span>
                <span class="invest-card-price-tag font-mono">{t.priceTagline}</span>
              </div>
            </header>
            <p class="invest-card-desc">{t.description}</p>
            <ul class="invest-card-features">
              {t.features.map((f) => (
                <li class="invest-card-feature">
                  <span class="invest-card-feature-dot" aria-hidden="true"></span>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
            <a
              href={t.ctaUrl}
              class={`btn ${t.flagship ? 'btn-primary' : 'btn-ghost'} invest-card-cta`}
            >
              {t.cta} <span class="btn-arrow">&rarr;</span>
            </a>
          </article>
        ))}
      </div>
    </div>

    <article class="invest-custom fade-up">
      <div class="invest-custom-content">
        <span class="invest-custom-eyebrow font-mono">Something else</span>
        <h3 class="invest-custom-title">Or something else entirely.</h3>
        <p class="invest-custom-extras font-mono">
          Brand-only &middot; Motion polish &middot; Photography days &middot; Copywriting &middot; Performance audits
        </p>
        <p class="invest-custom-close">
          Anything that doesn&rsquo;t fit a tier. Tell us what you&rsquo;re building and we&rsquo;ll scope it honestly.
        </p>
      </div>
      <a href="mailto:mark@rekraft.design?subject=Bespoke%20Project" class="btn btn-primary invest-custom-cta">
        Start a conversation <span class="btn-arrow">&rarr;</span>
      </a>
    </article>

    <p class="invest-foot fade-up">
      All numbers exclude VAT. Bespoke work is quoted to scope; the figures above are honest starting points. We take on a small number of projects each quarter.
    </p>
  </div>
</section>

<style>
  .invest {
    border-top: 1px solid var(--color-border);
    padding-block: clamp(56px, 6vw, 96px);
  }

  .invest-head {
    display: grid;
    gap: 14px;
    max-width: 720px;
    margin-bottom: clamp(28px, 3vw, 40px);
  }

  /* Tab toggle pill */
  .invest-tabs {
    display: inline-flex;
    gap: 4px;
    padding: 4px;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-card);
    margin-bottom: clamp(28px, 3vw, 40px);
  }
  .invest-tab {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
    padding: 10px 22px;
    border-radius: 999px;
    transition: color 0.35s var(--ease-out-expo), background 0.35s var(--ease-out-expo);
    cursor: pointer;
  }
  .invest-tab:hover { color: var(--color-ink); }
  .invest-tab.is-active {
    color: var(--color-bg);
    background: var(--color-ink);
  }

  /* Card groups (one per tab) */
  .invest-group {
    display: none;
    margin-bottom: clamp(28px, 3vw, 40px);
  }
  .invest-group.is-active { display: block; }

  /* Pricing grids */
  .invest-grid {
    display: grid;
    gap: clamp(20px, 2vw, 28px);
  }
  .invest-grid-3 { grid-template-columns: repeat(3, 1fr); }
  .invest-grid-2 {
    grid-template-columns: repeat(2, 1fr);
    max-width: 800px;
  }

  .invest-card {
    position: relative;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: clamp(28px, 2.6vw + 8px, 40px);
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition:
      opacity 0.4s var(--ease-out-expo),
      transform 0.4s var(--ease-out-expo),
      border-color 0.4s var(--ease-out-expo),
      box-shadow 0.4s var(--ease-out-expo);
  }

  /* Entry stagger */
  .invest-card.fade-up.is-in {
    transition:
      opacity 0.9s var(--ease-out-expo) var(--reveal-delay, 0s),
      transform 0.9s var(--ease-out-expo) var(--reveal-delay, 0s);
  }

  /* Hover focus: dim siblings within the same grid */
  .invest-grid:hover .invest-card:not(:hover) {
    opacity: 0.5;
    transform: scale(0.97);
  }

  .invest-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-border-active);
    box-shadow: 0 24px 60px -32px rgba(20, 20, 24, 0.28);
  }
  .invest-card.is-flagship {
    border-color: var(--color-border-active);
    box-shadow: 0 18px 50px -34px rgba(20, 20, 24, 0.22);
  }
  .invest-card.is-flagship:hover {
    box-shadow: 0 28px 70px -32px rgba(20, 20, 24, 0.34);
  }

  @media (prefers-reduced-motion: reduce) {
    .invest-grid:hover .invest-card:not(:hover) {
      opacity: 1;
      transform: none;
    }
  }

  .invest-badge {
    position: absolute;
    top: 18px;
    right: 20px;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-lime);
    padding: 5px 10px;
    border: 1px solid var(--color-lime);
    border-radius: 999px;
    background: var(--color-lime-soft);
  }

  .invest-card-head {
    display: grid;
    gap: 14px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--color-border);
  }
  .invest-card-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(24px, 1.6vw + 10px, 32px);
    line-height: 1;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    padding-bottom: 0.04em;
  }
  .invest-card-price-block { display: grid; gap: 4px; }
  .invest-card-price {
    font-size: clamp(36px, 3.2vw, 56px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    padding-bottom: 0.06em;
  }
  .invest-card-price-suffix {
    font-size: 16px;
    color: var(--color-ink-dim);
    letter-spacing: 0.01em;
    margin-left: 4px;
    font-weight: 400;
  }
  .invest-card-price-tag {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
    line-height: 1.4;
  }

  .invest-card-desc {
    font-size: clamp(14px, 0.3vw + 12px, 15px);
    line-height: 1.6;
    color: var(--color-ink-muted);
    max-width: 38ch;
  }

  .invest-card-features {
    list-style: none;
    display: grid;
    gap: 10px;
    padding-top: 8px;
    margin-top: auto;
  }
  .invest-card-feature {
    display: grid;
    grid-template-columns: 16px 1fr;
    align-items: start;
    gap: 12px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-ink-muted);
  }
  .invest-card-feature-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-lime);
    margin-top: 7px;
    margin-left: 4px;
  }

  .invest-card-cta {
    margin-top: 4px;
    justify-content: center;
    width: 100%;
  }

  /* Custom Request card */
  .invest-custom {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(24px, 4vw, 60px);
    align-items: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: clamp(28px, 3vw, 44px);
  }
  .invest-custom-content {
    display: grid;
    gap: 10px;
    max-width: 64ch;
  }
  .invest-custom-eyebrow {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }
  .invest-custom-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(24px, 1.6vw + 10px, 32px);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    padding-bottom: 0.04em;
    margin-bottom: 4px;
  }
  .invest-custom-extras {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
    line-height: 1.65;
    padding-top: 12px;
    margin-top: 4px;
    border-top: 1px solid var(--color-border);
  }
  .invest-custom-close {
    font-size: clamp(13px, 0.3vw + 11px, 14px);
    line-height: 1.6;
    color: var(--color-ink-dim);
    margin-top: 4px;
  }
  .invest-custom-cta { justify-self: start; }

  .invest-foot {
    font-family: var(--font-sans);
    font-size: 12px;
    line-height: 1.6;
    color: var(--color-ink-dim);
    max-width: 64ch;
    margin-top: clamp(24px, 3vw, 36px);
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 1000px) {
    .invest-grid-3 { grid-template-columns: 1fr; }
    .invest-grid-2 { grid-template-columns: 1fr; max-width: none; }
    .invest-custom { grid-template-columns: 1fr; gap: 20px; }
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.invest-tab');
  const groups = document.querySelectorAll<HTMLElement>('.invest-group');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach((t) => {
        const isActive = t === tab;
        t.classList.toggle('is-active', isActive);
        t.setAttribute('aria-selected', String(isActive));
      });
      groups.forEach((g) => {
        const isActive = g.dataset.group === target;
        g.classList.toggle('is-active', isActive);
        if (isActive) {
          // Force reveal on cards inside the newly visible group, in case
          // the global ScrollTrigger/IntersectionObserver hasn't fired for them
          // (they were display:none on initial load).
          g.querySelectorAll<HTMLElement>('.fade-up').forEach((el) => el.classList.add('is-in'));
        }
      });
    });
  });
</script>
