---
const principles = [
  { num: '01', title: 'Considered', body: 'Nothing without reason.' },
  { num: '02', title: 'Crafted', body: 'From scratch. By hand.' },
  { num: '03', title: 'Committed', body: 'We see it through.' },
];

const services = [
  { num: '01', name: 'Brand', headline: 'Identity systems that hold together.' },
  { num: '02', name: 'Websites', headline: 'Custom-built, never themed.' },
  { num: '03', name: 'Social', headline: 'Systems your team can actually run.' },
];

const process = [
  { num: '01', title: 'Discover', body: 'Listen. Audit. Scope.' },
  { num: '02', title: 'Design', body: 'Strategy. System. Screens.' },
  { num: '03', title: 'Build', body: 'Build. Test. Refine.' },
  { num: '04', title: 'Launch', body: 'Ship. Hand over. Train.' },
];
---

<section id="practice" class="section practice">
  <div class="frame">
    <header class="practice-head">
      <span class="eyebrow">02 &middot; Practice</span>
      <h2 class="display-2 reveal-words" data-reveal-headline>
        Our method. <em class="italic-accent">Our craft.</em>
      </h2>
    </header>

    <div class="practice-grid">
      <article class="practice-col fade-up">
        <header class="practice-col-head">
          <span class="practice-col-eyebrow font-mono">Principles</span>
        </header>
        <ol class="practice-col-list">
          {principles.map((p) => (
            <li class="practice-item">
              <span class="practice-item-num font-mono">{p.num}</span>
              <h3 class="practice-item-title">{p.title}</h3>
              <p class="practice-item-body" set:html={p.body}></p>
            </li>
          ))}
        </ol>
      </article>

      <article class="practice-col fade-up">
        <header class="practice-col-head">
          <span class="practice-col-eyebrow font-mono">Services</span>
        </header>
        <ol class="practice-col-list">
          {services.map((s) => (
            <li class="practice-item">
              <span class="practice-item-num font-mono">{s.num}</span>
              <h3 class="practice-item-title">{s.name}</h3>
              <p class="practice-item-headline">{s.headline}</p>
            </li>
          ))}
        </ol>
      </article>

      <article class="practice-col fade-up">
        <header class="practice-col-head">
          <span class="practice-col-eyebrow font-mono">Process</span>
        </header>
        <ol class="practice-col-list">
          {process.map((p) => (
            <li class="practice-item">
              <span class="practice-item-num font-mono">{p.num}</span>
              <h3 class="practice-item-title">{p.title}</h3>
              <p class="practice-item-body">{p.body}</p>
            </li>
          ))}
        </ol>
      </article>
    </div>
  </div>
</section>

<style>
  .practice {
    border-top: 1px solid var(--color-border);
    padding-block: clamp(56px, 6vw, 96px);
  }

  .practice-head {
    display: grid;
    gap: 14px;
    max-width: 720px;
    margin-bottom: clamp(28px, 3vw, 48px);
  }

  /* Three-column horizontal grid: Principles | Services | Process */
  .practice-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1.1fr;
    gap: clamp(28px, 3.5vw, 56px);
    max-width: 1180px;
    align-items: start;
  }

  .practice-col {
    display: grid;
    gap: clamp(18px, 2vw, 24px);
    align-content: start;
    /* Vertical divider between columns at desktop */
    padding-right: clamp(16px, 2vw, 32px);
    border-right: 1px solid var(--color-border);
  }
  .practice-col:last-child {
    padding-right: 0;
    border-right: 0;
  }

  .practice-col-head {
    padding-bottom: 14px;
    border-bottom: 1px solid var(--color-border);
  }
  .practice-col-eyebrow {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }

  .practice-col-list {
    list-style: none;
    display: grid;
    gap: clamp(20px, 2vw, 28px);
  }

  .practice-item {
    display: grid;
    gap: 6px;
  }
  .practice-item-num {
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--color-lime);
  }
  .practice-item-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(20px, 1.2vw + 10px, 28px);
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    padding-bottom: 0.04em;
  }
  .practice-item-body {
    font-family: var(--font-sans);
    font-size: clamp(13px, 0.2vw + 12px, 14px);
    line-height: 1.5;
    color: var(--color-ink-muted);
  }
  .practice-item-headline {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-cream);
    font-size: clamp(16px, 0.6vw + 12px, 19px);
    line-height: 1.25;
    margin-top: 2px;
  }
  .practice-item-body-meta {
    color: var(--color-ink-dim);
    font-size: clamp(12px, 0.2vw + 11px, 13px);
    margin-top: 2px;
  }

  @media (max-width: 900px) {
    .practice-grid {
      grid-template-columns: 1fr;
      gap: clamp(32px, 5vw, 48px);
    }
    .practice-col {
      padding-right: 0;
      border-right: 0;
      padding-bottom: clamp(24px, 4vw, 36px);
      border-bottom: 1px solid var(--color-border);
    }
    .practice-col:last-child {
      padding-bottom: 0;
      border-bottom: 0;
    }
  }
</style>
