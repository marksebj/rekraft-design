---
const services = [
  {
    num: '01',
    name: 'Brand',
    headline: 'Identity systems that hold together.',
    body: 'Logos, wordmarks, visual direction, guidelines. Built to hold up wherever your brand shows up.',
    deliverables: ['Identity system', 'Art direction', 'Guidelines', 'Asset library'],
  },
  {
    num: '02',
    name: 'Websites',
    headline: 'Fast, considered, built to perform.',
    body: 'Custom-built, not themed. Designed to convert without feeling like a funnel.',
    deliverables: ['Design', 'Development', 'CMS setup', 'Launch & support'],
  },
  {
    num: '03',
    name: 'Social',
    headline: 'Systems your team can actually run.',
    body: 'Templates and content that scale. The brand holds together whoever&rsquo;s posting.',
    deliverables: ['Content system', 'Templates', 'Monthly creative', 'Guidelines'],
  },
];
---

<section id="services" class="section services">
  <div class="frame">
    <header class="services-head">
      <span class="eyebrow">03 &mdash; Services</span>
      <h2 class="display-2 reveal-words" data-reveal-headline>
        Three things. <em class="italic-accent">Done properly.</em>
      </h2>
      <p class="lead fade-up">
        We go deep on what matters. No to the rest.
      </p>
    </header>

    <div class="services-list">
      {services.map((s) => (
        <article class="service fade-up">
          <div class="service-left">
            <span class="service-num font-mono">{s.num}</span>
            <h3 class="service-name display-2">{s.name}</h3>
          </div>
          <div class="service-right">
            <p class="service-headline display-3">{s.headline}</p>
            <p class="service-body">{s.body}</p>
            <ul class="service-deliverables">
              {s.deliverables.map((d) => <li class="font-mono">{d}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    border-top: 1px solid var(--color-border);
    padding-block: clamp(100px, 12vw, 180px);
  }

  .services-head {
    display: grid;
    gap: 20px;
    margin-bottom: clamp(64px, 8vw, 120px);
    max-width: 720px;
  }

  .services-list {
    display: grid;
    gap: 1px;
    background: var(--color-border);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .service {
    background: var(--color-bg);
    display: grid;
    grid-template-columns: minmax(260px, 1fr) 1.6fr;
    gap: clamp(32px, 5vw, 80px);
    padding: clamp(48px, 6vw, 80px) clamp(20px, 2.5vw, 40px);
    transition: background .6s var(--ease-out-expo);
  }
  .service:hover { background: var(--color-surface); }

  .service-left {
    display: grid;
    gap: 16px;
    align-content: start;
  }
  .service-num {
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--color-lime);
  }
  .service-name {
    font-size: clamp(56px, 8vw, 128px);
    line-height: 0.9;
    letter-spacing: -0.025em;
    color: var(--color-ink);
  }

  .service-right { display: grid; gap: 20px; align-content: start; max-width: 60ch; }
  .service-headline {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-cream);
    font-size: clamp(22px, 2vw + 10px, 34px);
    line-height: 1.2;
  }
  .service-body {
    font-size: clamp(15px, 0.6vw + 12px, 18px);
    line-height: 1.65;
    color: var(--color-ink-muted);
  }
  .service-deliverables {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 12px;
    padding-top: 20px;
    border-top: 1px solid var(--color-border);
  }
  .service-deliverables li {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
    padding: 6px 12px;
    border: 1px solid var(--color-border);
    border-radius: 999px;
  }

  @media (max-width: 900px) {
    .service {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 40px 20px;
    }
    .service-name { font-size: clamp(48px, 14vw, 96px); }
  }
</style>
