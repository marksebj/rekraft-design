---
const services = [
  {
    num: '01',
    name: 'Brand',
    headline: 'Identity systems that hold together.',
    body: 'Logos, wordmarks, visual direction, guidelines.',
  },
  {
    num: '02',
    name: 'Websites',
    headline: 'Fast, considered, built to perform.',
    body: 'Custom-built, never themed. Designed to convert without feeling like a funnel.',
  },
  {
    num: '03',
    name: 'Social',
    headline: 'Systems your team can actually run.',
    body: 'Templates and content that scale. The brand holds together whoever is posting.',
  },
];
---

<section id="services" class="section services">
  <div class="frame">
    <header class="services-head">
      <span class="eyebrow">03 &middot; Services</span>
      <h2 class="display-2 reveal-words" data-reveal-headline>
        Three things. <em class="italic-accent">Done properly.</em>
      </h2>
      <p class="lead fade-up">
        We go deep on what matters. No to the rest.
      </p>
    </header>

    <ol class="cat-list">
      {services.map((s) => (
        <li class="cat-row cat-row-service fade-up">
          <span class="cat-row-bracket cat-row-bracket-tl" aria-hidden="true"></span>
          <span class="cat-row-bracket cat-row-bracket-br" aria-hidden="true"></span>
          <div class="cat-row-prefix">
            <span class="cat-row-num font-mono">{s.num}</span>
            <span class="cat-row-name font-mono">{s.name}</span>
          </div>
          <div class="cat-row-content">
            <h3 class="cat-row-title cat-row-title-italic">{s.headline}</h3>
            <p class="cat-row-subtitle">{s.body}</p>
          </div>
          <span class="cat-row-arrow font-mono" aria-hidden="true">&rarr;</span>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .services {
    border-top: 1px solid var(--color-border);
    padding-block: clamp(56px, 6vw, 96px);
  }

  .services-head {
    display: grid;
    gap: 14px;
    max-width: 720px;
    margin-bottom: clamp(28px, 3vw, 48px);
  }

  /* Category-list row pattern — shared shape with Approach */
  .cat-list {
    list-style: none;
    display: grid;
    gap: 8px;
    max-width: 1080px;
  }
  .cat-row {
    position: relative;
    height: 96px;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-card);
    display: grid;
    grid-template-columns: 200px 1fr auto;
    align-items: center;
    padding: 0 28px;
    column-gap: 28px;
    overflow: hidden;
    transition:
      height 0.45s var(--ease-out-expo),
      border-color 0.45s var(--ease-out-expo),
      background 0.45s var(--ease-out-expo),
      box-shadow 0.45s var(--ease-out-expo);
  }
  .cat-row:hover {
    height: 124px;
    border-color: var(--color-border-active);
    background: var(--color-card-hover);
    box-shadow: 0 18px 32px -28px rgba(20, 20, 24, 0.22);
  }

  .cat-row-prefix {
    display: flex;
    align-items: baseline;
    gap: 14px;
    border-right: 1px solid var(--color-border);
    height: 100%;
    padding-right: 24px;
    align-self: stretch;
    align-content: center;
    flex-wrap: wrap;
  }
  .cat-row-num {
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--color-lime);
  }
  .cat-row-name {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink);
  }

  .cat-row-content {
    display: grid;
    gap: 4px;
  }
  .cat-row-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(20px, 1.4vw + 10px, 28px);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    padding-bottom: 0.04em;
  }
  .cat-row-title-italic {
    font-style: italic;
    color: var(--color-cream);
  }
  .cat-row-subtitle {
    font-family: var(--font-sans);
    font-size: clamp(13px, 0.3vw + 11px, 15px);
    line-height: 1.5;
    color: var(--color-ink-muted);
    max-width: 64ch;
  }
  .cat-row-arrow {
    font-size: 13px;
    color: var(--color-lime);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.3s var(--ease-out-expo), transform 0.4s var(--ease-out-expo);
  }
  .cat-row:hover .cat-row-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .cat-row-bracket {
    position: absolute;
    width: 12px;
    height: 12px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s var(--ease-out-expo);
  }
  .cat-row-bracket-tl {
    top: 8px;
    left: 8px;
    border-top: 1px solid var(--color-lime);
    border-left: 1px solid var(--color-lime);
  }
  .cat-row-bracket-br {
    bottom: 8px;
    right: 8px;
    border-bottom: 1px solid var(--color-lime);
    border-right: 1px solid var(--color-lime);
  }
  .cat-row:hover .cat-row-bracket { opacity: 1; }

  @media (max-width: 800px) {
    .cat-row {
      height: auto;
      min-height: 96px;
      padding: 18px 20px;
      grid-template-columns: 1fr;
      column-gap: 0;
      row-gap: 12px;
    }
    .cat-row-prefix {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
      padding: 0 0 12px;
      height: auto;
    }
    .cat-row-arrow { display: none; }
  }
</style>
